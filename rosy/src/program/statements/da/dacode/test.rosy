BEGIN;
    VARIABLE (VE) params;
    VARIABLE (RE 10 2) result;
    DAINI 3 2 0 0;
    params := 3&2;
    DACODE params 10 result;
    { Print exponents for all 10 monomials (graded lex order) }
    WRITE 6 'M1:' result(1)(1) result(1)(2);
    WRITE 6 'M2:' result(2)(1) result(2)(2);
    WRITE 6 'M3:' result(3)(1) result(3)(2);
    WRITE 6 'M4:' result(4)(1) result(4)(2);
    WRITE 6 'M5:' result(5)(1) result(5)(2);
    WRITE 6 'M6:' result(6)(1) result(6)(2);
    WRITE 6 'M7:' result(7)(1) result(7)(2);
    WRITE 6 'M8:' result(8)(1) result(8)(2);
    WRITE 6 'M9:' result(9)(1) result(9)(2);
    WRITE 6 'M10:' result(10)(1) result(10)(2);
    WRITE 6 'dacode ok';
END;
