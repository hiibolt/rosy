BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE X 2000 1;
    VARIABLE VINFO 5;
    VARIABLE LEN 1;
    VARIABLE DVAL 1 10000;
    VARIABLE IVAL 1 10000;
    VARIABLE DAPAR 5;
    DAINI 3 2 0 NM;
    X(1) := DA(1);
    LEN := 10000;
    WRITEM X VINFO LEN DVAL IVAL DAPAR;
    WRITE 6 'NM:' NM;
    WRITE 6 'DAPAR:' DAPAR;
    WRITE 6 'dacode ok';
ENDPROCEDURE;
RUN;
END;
