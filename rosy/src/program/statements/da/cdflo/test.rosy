BEGIN;
    { 1D exponential: z' = z, ic = CD(1) }
    { Flow: z(1) = e * x1, coefficient of x1 = e ≈ 2.71828 }
    VARIABLE (CD 1) rhs;
    VARIABLE (CD 1) ic;
    VARIABLE (CD 1) result;
    VARIABLE (DA 1) real_part;
    DAINI 3 1 0 0;
    rhs(1) := CD(1);
    ic(1) := CD(1);
    CDFLO rhs ic result 1;
    real_part(1) := REAL(result(1));
    DAPRV real_part 1 1 1 6;
    WRITE 6 'cdflo ok';
END;
