BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE f 2000 2;
    VARIABLE g 2000;
    VARIABLE result 2000 1;
    DAINI 3 2 0 NM;
    f(1) := DA(2);
    f(2) := DA(1);
    g := DA(1)*DA(1) + DA(2)*DA(2);
    result(1) := 0*DA(1);
    DAGMD g f result 2;
    DAPRV result 1 2 2 6;
    WRITE 6 'dagmd ok';
ENDPROCEDURE;
RUN;
END;
