BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE rhs 2000 2;
    VARIABLE ic 2000;
    VARIABLE result 2000;
    DAINI 5 2 0 NM;
    rhs(1) := DA(2);
    rhs(2) := -1*DA(1);
    { Component 1: ic = x1 }
    ic := DA(1);
    DAFLO rhs ic result 2;
    WRITE 6 result;
    WRITE 6 '---';
    { Component 2: ic = x2 }
    ic := DA(2);
    DAFLO rhs ic result 2;
    WRITE 6 result;
    WRITE 6 'daflo ok';
ENDPROCEDURE;
RUN;
END;
