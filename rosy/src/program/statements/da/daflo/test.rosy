BEGIN;
    { Harmonic oscillator: x1' = x2, x2' = -x1 }
    { Exact flow at t=1: x1 -> cos(1)*x1 + sin(1)*x2 }
    {                     x2 -> -sin(1)*x1 + cos(1)*x2 }
    VARIABLE (DA 2) rhs;
    VARIABLE (DA 2) ic;
    VARIABLE (DA 2) result;
    DAINI 5 2 0 0;
    rhs(1) := DA(2);
    rhs(2) := -1*DA(1);
    ic(1) := DA(1);
    ic(2) := DA(2);
    DAFLO rhs ic result 2;
    DAPRV result 1 2 2 6;
    WRITE 6 '---';
    DAPRV result 2 2 2 6;
    WRITE 6 'daflo ok';
END;
