BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE INPUT 2000;
    VARIABLE OUTPUT 2000;
    VARIABLE SCALES 100;
    VARIABLE SHIFTS 100;
    OV 3 2 0 NM;
    INPUT(1) := DA(1);
    SCALES := 2.0 & 1.0;
    SHIFTS := 1.0 & 0.0;
    DATRN INPUT SCALES SHIFTS 1 1 OUTPUT;
    DAPRV OUTPUT 1 2 2 6;
ENDPROCEDURE;
RUN;
END;