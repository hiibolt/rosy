BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE INPUT 2000;
    VARIABLE OUTPUT 2000;
    VARIABLE SCALES 1 2;
    VARIABLE SHIFTS 1 2;
    DAINI 3 2 0 NM;
    INPUT := DA(1);
    SCALES(1) := 2.0;
    SCALES(2) := 1.0;
    SHIFTS(1) := 1.0;
    SHIFTS(2) := 0.0;
    DATRN INPUT SCALES SHIFTS 1 1 OUTPUT;
    WRITE 6 'datrn ok';
ENDPROCEDURE;
RUN;
END;
