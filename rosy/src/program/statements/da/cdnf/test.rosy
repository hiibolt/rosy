BEGIN;
    { CDNF: Solve homological equation 1/(1-exp(:f2:)) }
    VARIABLE (CD 1) A;
    VARIABLE (CD 1) R;
    VARIABLE (VE) resonances;
    VARIABLE (VE) res_dims;
    VARIABLE (DA 1) rp;
    DAINI 3 4 0 0;

    A(1) := CD(1);
    resonances := 0&0&0;
    res_dims := 0&0&0;

    CDNF A 0.7853981633974483 0.0 0.0 resonances res_dims 0 R;

    rp(1) := REAL(R(1));
    DAPRV rp 1 4 4 6;
    WRITE 6 'cdnf ok';
END;
