BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE template 2000;
    VARIABLE A 2000 1;
    VARIABLE B 2000 1;
    DAINI 3 2 0 NM;
    template := DA(1) + DA(2);
    A(1) := DA(1) + 2*DA(2) + 3*DA(1)*DA(2);
    DAFSET template;
    DAFILT A B;
    DAPRV B 1 2 2 6;
    WRITE 6 'dafilt ok';
ENDPROCEDURE;
RUN;
END;
