BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE A 2000 5;
    VARIABLE B 2000 5;
    DAINI 3 2 0 NM;
    A(1) := DA(1) + 3;
    A(2) := DA(2);
    A(3) := 0*DA(1);
    A(4) := 0*DA(1);
    A(5) := 0*DA(1);
    B(1) := 0*DA(1);
    B(2) := 0*DA(1);
    B(3) := 0*DA(1);
    B(4) := 0*DA(1);
    B(5) := 0*DA(1);
    OPENF 20 'test_darev_tmp.dat' 'UNKNOWN';
    DAPRV A 5 2 2 20;
    CLOSEF 20;
    OPENF 20 'test_darev_tmp.dat' 'OLD';
    DAREV B 5 2 2 20;
    CLOSEF 20;
    WRITE 6 'darev ok';
ENDPROCEDURE;
RUN;
END;
