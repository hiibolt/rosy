BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE A 2000 1;
    VARIABLE B 2000;
    DAINI 3 2 0 NM;
    A(1) := DA(1) + 3;
    OPENF 21 'test_darea_tmp.dat' 'UNKNOWN';
    DAPRV A 1 2 2 21;
    CLOSEF 21;
    OPENF 21 'test_darea_tmp.dat' 'OLD';
    DAREA 21 B 2;
    CLOSEF 21;
    WRITE 6 'darea ok';
ENDPROCEDURE;
RUN;
END;
