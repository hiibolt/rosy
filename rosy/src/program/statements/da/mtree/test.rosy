BEGIN;
    DAINI 3 2 0 0;
    VARIABLE (DA 2) MAP;
    MAP(1) := DA(1) + 0.1 * DA(2);
    MAP(2) := DA(2) + 0.1 * DA(1);
    VARIABLE (RE 100) COEFF;
    VARIABLE (RE 100) STEER1;
    VARIABLE (RE 100) STEER2;
    VARIABLE (RE) ELEM2;
    VARIABLE (RE) TLEN;
    MTREE MAP 2 COEFF STEER1 STEER2 ELEM2 TLEN;
    WRITE 6 'mtree ok';
END;