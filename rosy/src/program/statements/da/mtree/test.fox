BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE MAP 2000 1;
    VARIABLE ELEM1 1;
    VARIABLE COEFF 1 100;
    VARIABLE STEER1 1 100;
    VARIABLE STEER2 1 100;
    VARIABLE ELEM2 1;
    VARIABLE TLEN 1;
    DAINI 3 2 0 NM;
    MAP(1) := DA(1) + 0.1*DA(2);
    ELEM1 := 1;
    MTREE MAP ELEM1 COEFF STEER1 STEER2 ELEM2 TLEN;
    WRITE 6 TLEN;
    WRITE 6 'mtree ok';
ENDPROCEDURE;
RUN;
END;
