BEGIN;
    VARIABLE (RE) INPUT_0;
    VARIABLE (RE) RESULT_0;

    INPUT_0 := 1.5;
    RESULT_0 := CONJ(INPUT_0);
    WRITE 6 ST(RESULT_0);

    VARIABLE (CM) INPUT_1;
    VARIABLE (CM) RESULT_1;

    INPUT_1 := CM(1.5&2.5);
    RESULT_1 := CONJ(INPUT_1);
    WRITE 6 ST(RESULT_1);

    VARIABLE (CD) INPUT_2;
    VARIABLE (CD) RESULT_2;

    INPUT_2 := CD(1);
    RESULT_2 := CONJ(INPUT_2);
    WRITE 6 ST(RESULT_2);

END;
