BEGIN;
    VARIABLE (RE) INPUT_0;
    VARIABLE (RE) RESULT_0;

    INPUT_0 := 4.0;
    RESULT_0 := ISRT3(INPUT_0);
    WRITE 6 ST(RESULT_0);

    VARIABLE (VE) INPUT_1;
    VARIABLE (VE) RESULT_1;

    INPUT_1 := 4.0&9.0&16.0;
    RESULT_1 := ISRT3(INPUT_1);
    WRITE 6 ST(RESULT_1);

    VARIABLE (DA) INPUT_2;
    VARIABLE (DA) RESULT_2;

    INPUT_2 := 4.0 + DA(1);
    RESULT_2 := ISRT3(INPUT_2);
    WRITE 6 ST(RESULT_2);

END;
