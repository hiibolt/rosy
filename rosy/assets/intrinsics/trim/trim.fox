BEGIN;

PROCEDURE RUN;
    { All variable declarations must come first in FOX/COSY }
    VARIABLE NM 1;
    VARIABLE INPUT_0 6;
    VARIABLE RESULT_0 6;

    { Initialize DA system for tests that use DA/CD types }
    { DAINI: order 10, number_of_variables 6, mode 0 (see COSY manual) }
    DAINI 10 6 0 NM;

    { Test 0: TRIM(ST) => ST }
    INPUT_0 := '  hello  ';
    RESULT_0 := TRIM(INPUT_0);
    WRITE 6 RESULT_0;

ENDPROCEDURE;

RUN;
END;
