BEGIN;
    VARIABLE (RE) INPUT_0;
    VARIABLE (RE) RESULT_0;

    INPUT_0 := 0.5;
    RESULT_0 := ACOS(INPUT_0);
    WRITE 6 ST(RESULT_0);

    VARIABLE (VE) INPUT_1;
    VARIABLE (VE) RESULT_1;

    INPUT_1 := 0.1&0.2&0.3;
    RESULT_1 := ACOS(INPUT_1);
    WRITE 6 ST(RESULT_1);

    VARIABLE (DA) INPUT_2;
    VARIABLE (DA) RESULT_2;

    INPUT_2 := DA(1);
    RESULT_2 := ACOS(INPUT_2);
    WRITE 6 ST(RESULT_2);

END;
