BEGIN;

PROCEDURE RUN;
    { All variable declarations must come first in FOX/COSY }
    VARIABLE NM 1;
    VARIABLE INPUT_0 6;
    VARIABLE RESULT_0 1;

    { Initialize DA system for tests that use DA/CD types }
    { DAINI: order 10, number_of_variables 6, mode 0 (see COSY manual) }
    DAINI 10 6 0 NM;

    { Test 0: VMIN(VE) => RE }
    INPUT_0 := 1.5&2.5&3.5;
    RESULT_0 := VMIN(INPUT_0);
    WRITE 6 RESULT_0;

ENDPROCEDURE;

RUN;
END;
