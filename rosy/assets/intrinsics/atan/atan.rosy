BEGIN;
    VARIABLE (RE) INPUT_0;
    VARIABLE (RE) RESULT_0;

    INPUT_0 := 1.5;
    RESULT_0 := ATAN(INPUT_0);
    WRITE 6 ST(RESULT_0);

    VARIABLE (VE) INPUT_1;
    VARIABLE (VE) RESULT_1;

    INPUT_1 := 1.5&2.5&3.5;
    RESULT_1 := ATAN(INPUT_1);
    WRITE 6 ST(RESULT_1);

    VARIABLE (DA) INPUT_2;
    VARIABLE (DA) RESULT_2;

    INPUT_2 := DA(1);
    RESULT_2 := ATAN(INPUT_2);
    WRITE 6 ST(RESULT_2);

END;
