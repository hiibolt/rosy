BEGIN;
PROCEDURE RUN;
    VARIABLE NM 1;
    VARIABLE MAP 4000;
    VARIABLE COEFF 100;
    VARIABLE STEER1 100;
    VARIABLE STEER2 100;
    VARIABLE ELEM2 1;
    VARIABLE TLEN 1;
    OV 3 2 0 NM;
    MAP(1) := DA(1) + 0.1 * DA(2);
    MAP(2) := DA(2) + 0.1 * DA(1);
    MTREE MAP 2 COEFF STEER1 STEER2 ELEM2 TLEN;
    WRITE 6 'mtree ok';
ENDPROCEDURE;
RUN;
END;