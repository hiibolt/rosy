WHITESPACE = _{ " " | "\t" | NEWLINE }

// Comments use {..} syntax with support for nested {..} blocks
// e.g. {LOOP I 1 N; X := {inner comment} 1; ENDLOOP;} is one comment
COMMENT = _{ "{" ~ (COMMENT | (!("{" | "}") ~ ANY))* ~ "}" }

program = { SOI ~ begin ~ statement* ~ end ~ EOI }
statement   = _{ 
  var_decl
  | daini
  | daprv
  | darev
  | writeb
  | write
  | reads
  | readb
  | read
  | openfb
  | openf
  | closef
  | rewf
  | backf
  | assignment
  | function
  | loop
  | while_loop
  | ploop
  | procedure
  | ranseed
  | writem
  | readm
  | intpol
  | procedure_call
  | if_statement
  | break_statement
  | fit_statement
  | scrlen
  | cpusec
  | quit
  | os_call
  | danot
  | daeps
  | datrn
  | dascl
  | dasgn
  | dader
  | daint
  | danoro
  | danors
  | daplu
  | dadiu
  | dadmu
  | dacliw
  | dacqlc
  | darea
  | dapew
  | dapee
  | dapea
  | dapep
  | daest
  | daepsm
  | epsmin
  | dafset
  | dafilt
  | danotw
  | daflo
  | cdflo
  | dagmd
  | danow
  | cdf2
  | cdnfds
  | cdnfda
  | cdnf
  | daran
  | dacode
  | linv
  | ldet
  | substr
  | velset
  | velget
  | polval
  | vedot
  | veunit
  | vezero
  | stcre
  | recst
  | reran
  | pwtime
  | pnpro
  | imunit
  | lev
  | mblock
  | mtree
  | sleepm
  | argget
  | memdpv
  | memfre
  | memall
  | memwrt
  | ltrue
  | lfalse
  | lsline
  | rkco }

/// BREAK
break_statement = { ^"BREAK" ~ semicolon }

/// BEGIN and END
begin = { ^"BEGIN" ~ semicolon }
end = { ^"END" ~ semicolon }

/// WRITE
writeb = { ^"WRITEB" ~ expr ~ expr+ ~ semicolon }
write = { ^"WRITE" ~ expr ~ expr+ ~ semicolon }
reads = { ^"READS" ~ expr ~ variable_identifier ~ semicolon }
readb = { ^"READB" ~ expr ~ variable_identifier ~ semicolon }
read = { ^"READ" ~ expr ~ variable_identifier ~ semicolon }

/// FILE I/O
openfb = { ^"OPENFB" ~ expr ~ expr ~ expr ~ semicolon }
openf = { ^"OPENF" ~ expr ~ expr ~ expr ~ semicolon }
closef = { ^"CLOSEF" ~ expr ~ semicolon }
rewf = { ^"REWF" ~ expr ~ semicolon }
backf = { ^"BACKF" ~ expr ~ semicolon }

/// VARIABLE
/// In Rosy mode (default): `VARIABLE (RE) name dim1 dim2 ;` — all trailing exprs are dimensions.
/// In COSY mode (--cosy-syntax): `VARIABLE name memsize dim1 ;` — first expr is required memory size (discarded).
/// Validation of which mode applies is done in AST construction, not grammar.
var_decl = { ^"VARIABLE" ~ type? ~ variable_name ~ memory_size* ~ semicolon }
memory_size = { expr }

/// Keywords - define all reserved words (must be followed by a non-identifier character)
keyword = @{ keyword_raw ~ !(ASCII_ALPHANUMERIC | "_") }
keyword_raw = { ^"ENDPROCEDURE" | ^"ENDFUNCTION" | ^"ENDWHILE" | ^"ENDLOOP" | ^"ENDPLOOP" | ^"ENDFIT" | ^"ENDIF" | ^"ELSEIF" | ^"ELSE" | ^"BEGIN" | ^"END" | ^"WRITEB" | ^"WRITE" | ^"READS" | ^"READB" | ^"READ" | ^"VARIABLE" | ^"PROCEDURE" | ^"EXP" | ^"TAN" | ^"IF" | ^"WHILE" | ^"TRUE" | ^"FALSE" | ^"DAINI" | ^"DAPRV" | ^"DAREV" | ^"DANOTW" | ^"DANOT" | ^"DAEPSM" | ^"DAEPS" | ^"DATRN" | ^"DASCL" | ^"DASGN" | ^"DADER" | ^"DAINT" | ^"DANORO" | ^"DANORS" | ^"DAREA" | ^"DAPEW" | ^"DAPEE" | ^"DAPEA" | ^"DAPEP" | ^"DAEST" | ^"DAPLU" | ^"DADIU" | ^"DADMU" | ^"DACLIW" | ^"DACQLC" | ^"EPSMIN" | ^"DAFSET" | ^"DAFILT" | ^"DAFLO" | ^"CDFLO" | ^"DAGMD" | ^"DANOW" | ^"CDF2" | ^"CDNFDS" | ^"CDNFDA" | ^"CDNF" | ^"DARAN" | ^"DACODE" | ^"LENGTH" | ^"SINH" | ^"SIN" | ^"COSH" | ^"COS" | ^"ASIN" | ^"ACOS" | ^"ATAN" | ^"TANH" | ^"SQRT" | ^"SQR" | ^"VMAX" | ^"VMIN" | ^"ABS" | ^"NORM" | ^"CONS" | ^"INTPOL" | ^"INT" | ^"NINT" | ^"TYPE" | ^"REAL" | ^"IMAG" | ^"TRIM" | ^"LTRIM" | ^"ISRT3" | ^"ISRT" | ^"CMPLX" | ^"CONJ" | ^"LST" | ^"LCM" | ^"LCD" | ^"LRE" | ^"LLO" | ^"LVE" | ^"LDA" | ^"LOG" | ^"BREAK" | ^"QUIT" | ^"SCRLEN" | ^"CPUSEC" | ^"OS" | ^"LINV" | ^"LDET" | ^"SUBSTR" | ^"VELSET" | ^"VELGET" | ^"INTPOL" | ^"POLVAL" | ^"VEDOT" | ^"VEUNIT" | ^"VEZERO" | ^"STCRE" | ^"RECST" | ^"RERAN" | ^"PWTIME" | ^"PNPRO" | ^"IMUNIT" | ^"LEV" | ^"MBLOCK" | ^"MTREE" | ^"LSLINE" | ^"RKCO" | ^"WRITEM" | ^"READM" | ^"ERF" | ^"WERF" | ^"FIT" | ^"OPENFB" | ^"OPENF" | ^"CLOSEF" | ^"REWF" | ^"BACKF" | ^"FUNCTION" | ^"LOOP" | ^"PLOOP" | ^"VARMEM" | ^"VARPOI" | ^"SLEEPM" | ^"ARGGET" | ^"MEMDPV" | ^"MEMFRE" | ^"MEMALL" | ^"MEMWRT" | ^"LTRUE" | ^"LFALSE" | "rosy_universe" | "rosy_world" | "rosy_size" | "rosy_rank" | ^"AND" | ^"OR" | ^"POSITION" }

/// [ IF / ELSEIF / ELSE / ENDIF ]
if_statement = { if_clause ~ elseif_clause* ~ else_clause? ~ endif }
if_clause = { ^"IF" ~ expr ~ semicolon ~ statement* }
elseif_clause = { ^"ELSEIF" ~ expr ~ semicolon ~ statement* }
else_clause = { ^"ELSE" ~ semicolon ~ statement* }
endif = { ^"ENDIF" ~ semicolon }

/// [ PROCEDURES / FUNCTIONS ]
  ///
  /// [ PROCEDURES ]
  /// Container
  procedure = { start_procedure ~ statement* ~ end_procedure }
  /// Calling - ensure the name is not a keyword
  procedure_call = { procedure_name ~ expr* ~ semicolon }
  /// PROCEDURE
  start_procedure = { ^"PROCEDURE" ~ procedure_name ~ procedure_argument_name_and_type* ~ semicolon }
  procedure_name = @{ !keyword ~ (ASCII_ALPHANUMERIC | "_")+ }
  procedure_argument_name_and_type = { procedure_argument_name ~ type? }
  procedure_argument_name = @{ !keyword ~ (ASCII_ALPHANUMERIC | "_")+ }
  /// ENDPROCEDURE
  end_procedure = { ^"ENDPROCEDURE" ~ semicolon }
  ///
  /// [ FUNCTIONS ]
  /// Container
  function = { start_function ~ statement* ~ end_function }
  /// Calling - ensure the name is not a keyword
  function_call = { function_name ~ "(" ~ expr ~ ("," ~ expr)* ~ ")"  }
  /// FUNCTION
  start_function = { ^"FUNCTION" ~ type? ~ function_name ~ function_argument_name_and_type+ ~ semicolon }
  function_name = @{ !keyword ~ (ASCII_ALPHANUMERIC | "_")+ }
  function_argument_name_and_type = _{ function_argument_name ~ type? }
  function_argument_name = @{ !keyword ~ (ASCII_ALPHANUMERIC | "_")+ }
  /// ENDFUNCTION
  end_function = { ^"ENDFUNCTION" ~ semicolon }

/// [ LOOPS / WHILES ]
  ///
  /// [ LOOP ]
  loop = { start_loop ~ statement+ ~ end_loop }
  start_loop = { ^"LOOP" ~ variable_name ~ expr ~ expr ~ expr? ~ semicolon }
  end_loop = { ^"ENDLOOP" ~ semicolon }
  /// [ PLOOP ]
  ploop = { start_ploop ~ statement+ ~ end_ploop }
  start_ploop = { ^"PLOOP" ~ variable_name ~ expr ~ expr ~ semicolon }
  end_ploop = { ^"ENDPLOOP" ~ unit? ~ variable_identifier ~ semicolon }
  /// [ WHILE ]
  while_loop = { start_while ~ statement* ~ end_while }
  start_while = { ^"WHILE" ~ expr ~ semicolon }
  end_while = { ^"ENDWHILE" ~ semicolon }
  /// [ FIT ]
  fit_statement = { start_fit ~ statement* ~ end_fit }
  start_fit = { ^"FIT" ~ variable_name+ ~ semicolon }
  end_fit = { ^"ENDFIT" ~ expr ~ expr ~ expr ~ variable_name+ ~ semicolon }

/// [ INTRINSIC FUNCTIONS ]
  builtin_function = _{ cm | st | lo | da | cd_intrinsic | position | length | varmem | varpoi | sin | cos_fn | asin_fn | acos_fn | atan_fn | sinh_fn | cosh_fn | tanh_fn | sqrt_fn | sqr | exp_fn | log_fn | tan_fn | vmax | vmin | abs_fn | norm_fn | cons_fn | int_fn | nint_fn | type_fn | real_fn | imag_fn | re_fn | ve_fn | trim_fn | ltrim_fn | isrt3_fn | isrt_fn | cmplx_fn | conj_fn | lst | lcm | lcd | lre | llo | lve | lda | werf_fn | erf_fn }
  /// CM
  cm = { ^"CM" ~ "(" ~ expr ~ ")" }
  /// ST - String conversion
  st = { ^"ST" ~ "(" ~ expr ~ ")" }
  /// LO - Logical conversion
  lo = { ^"LO" ~ "(" ~ expr ~ ")" }
  /// DA - Create DA identity vector
  da = { ^"DA" ~ "(" ~ expr ~ ")" }
  /// CD - Create CD identity vector
  cd_intrinsic = { ^"CD" ~ "(" ~ expr ~ ")" }
  /// POSITION - Find substring position
  position = { ^"POSITION" ~ "(" ~ expr ~ "," ~ expr ~ ")" }
  /// LENGTH - Get memory size
  length = { ^"LENGTH" ~ "(" ~ expr ~ ")" }
  /// SIN - Compute sine
  sin = { ^"SIN" ~ "(" ~ expr ~ ")" }
  /// COS - Compute cosine
  cos_fn = { ^"COS" ~ "(" ~ expr ~ ")" }
  /// ASIN - Compute arcsine
  asin_fn = { ^"ASIN" ~ "(" ~ expr ~ ")" }
  /// ACOS - Compute arccosine
  acos_fn = { ^"ACOS" ~ "(" ~ expr ~ ")" }
  /// ATAN - Compute arctangent
  atan_fn = { ^"ATAN" ~ "(" ~ expr ~ ")" }
  /// SINH - Compute hyperbolic sine
  sinh_fn = { ^"SINH" ~ "(" ~ expr ~ ")" }
  /// COSH - Compute hyperbolic cosine
  cosh_fn = { ^"COSH" ~ "(" ~ expr ~ ")" }
  /// TANH - Compute hyperbolic tangent
  tanh_fn = { ^"TANH" ~ "(" ~ expr ~ ")" }
  /// SQR - Compute square
  sqr = { ^"SQR" ~ "(" ~ expr ~ ")" }
  /// SQRT - Compute square root
  sqrt_fn = { ^"SQRT" ~ "(" ~ expr ~ ")" }
  /// EXP - Compute exponential
  exp_fn = { ^"EXP" ~ "(" ~ expr ~ ")" }
  /// LOG - Compute natural logarithm
  log_fn = { ^"LOG" ~ "(" ~ expr ~ ")" }
  /// TAN - Compute tangent
  tan_fn = { ^"TAN" ~ "(" ~ expr ~ ")" }
  /// VMAX - Maximum element of vector
  vmax = { ^"VMAX" ~ "(" ~ expr ~ ")" }
  /// VMIN - Minimum element of vector
  vmin = { ^"VMIN" ~ "(" ~ expr ~ ")" }
  /// ABS - Absolute value
  abs_fn = { ^"ABS" ~ "(" ~ expr ~ ")" }
  /// NORM - Compute norm
  norm_fn = { ^"NORM" ~ "(" ~ expr ~ ")" }
  /// CONS - Extract constant part
  cons_fn = { ^"CONS" ~ "(" ~ expr ~ ")" }
  /// INT - Truncate toward zero
  int_fn = { ^"INT" ~ "(" ~ expr ~ ")" }
  /// NINT - Round to nearest integer
  nint_fn = { ^"NINT" ~ "(" ~ expr ~ ")" }
  /// TYPE - Return COSY type code
  type_fn = { ^"TYPE" ~ "(" ~ expr ~ ")" }
  /// REAL - Determine the real part
  real_fn = { ^"REAL" ~ "(" ~ expr ~ ")" }
  /// IMAG - Determine the imaginary part
  imag_fn = { ^"IMAG" ~ "(" ~ expr ~ ")" }
  /// RE - Convert to real number
  re_fn = { ^"RE" ~ "(" ~ expr ~ ")" }
  /// VE - Convert to vector
  ve_fn = { ^"VE" ~ "(" ~ expr ~ ")" }
  /// TRIM - Remove trailing spaces
  trim_fn = { ^"TRIM" ~ "(" ~ expr ~ ")" }
  /// LTRIM - Remove leading spaces
  ltrim_fn = { ^"LTRIM" ~ "(" ~ expr ~ ")" }
  /// ISRT3 - Inverse cube-root (x^(-3/2)) -- must appear before ISRT
  isrt3_fn = { ^"ISRT3" ~ "(" ~ expr ~ ")" }
  /// ISRT - Inverse square root (x^(-1/2))
  isrt_fn = { ^"ISRT" ~ "(" ~ expr ~ ")" }
  /// CMPLX - Convert to complex
  cmplx_fn = { ^"CMPLX" ~ "(" ~ expr ~ ")" }
  /// CONJ - Complex conjugate
  conj_fn = { ^"CONJ" ~ "(" ~ expr ~ ")" }
  /// LST - String memory size estimator (compatibility)
  lst = { ^"LST" ~ "(" ~ expr ~ ")" }
  /// LCM - Complex memory size estimator (compatibility)
  lcm = { ^"LCM" ~ "(" ~ expr ~ ")" }
  /// LCD - DA memory size estimator (compatibility)
  lcd = { ^"LCD" ~ "(" ~ expr ~ ")" }
  /// LRE - Real memory size estimator (compatibility)
  lre = { ^"LRE" ~ "(" ~ expr ~ ")" }
  /// LLO - Logical memory size estimator (compatibility)
  llo = { ^"LLO" ~ "(" ~ expr ~ ")" }
  /// LVE - Vector memory size estimator (compatibility)
  lve = { ^"LVE" ~ "(" ~ expr ~ ")" }
  /// LDA - DA memory size estimator (compatibility)
  lda = { ^"LDA" ~ "(" ~ expr ~ ")" }
  /// WERF - Faddeeva function w(z) = exp(-z^2)*erfc(-iz) -- must appear before ERF
  werf_fn = { ^"WERF" ~ "(" ~ expr ~ ")" }
  /// ERF - Real error function erf(x)
  erf_fn = { ^"ERF" ~ "(" ~ expr ~ ")" }
  /// VARMEM - Memory address of an object
  varmem = { ^"VARMEM" ~ "(" ~ expr ~ ")" }
  /// VARPOI - Pointer address of an object
  varpoi = { ^"VARPOI" ~ "(" ~ expr ~ ")" }

/// [ INTRINSIC PROCEDURES ]
  /// [ DA ]
  daini = { ^"DAINI" ~ expr ~ expr ~ (expr ~ (daini_nm_zero | expr))? ~ semicolon }
  daini_nm_zero = @{ "0" ~ !(ASCII_ALPHANUMERIC | "_" | ".") }
  daprv = { ^"DAPRV" ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  darev = { ^"DAREV" ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  danot = { ^"DANOT" ~ expr ~ semicolon }
  daeps = { ^"DAEPS" ~ expr ~ semicolon }
  datrn  = { ^"DATRN"  ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  dascl  = { ^"DASCL"  ~ expr ~ expr ~ semicolon }
  dasgn  = { ^"DASGN"  ~ expr ~ semicolon }
  dader  = { ^"DADER"  ~ expr ~ expr ~ semicolon }
  daint  = { ^"DAINT"  ~ expr ~ expr ~ semicolon }
  danoro = { ^"DANORO" ~ expr ~ semicolon }
  danors = { ^"DANORS" ~ expr ~ expr ~ semicolon }
  daplu  = { ^"DAPLU"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  dadiu  = { ^"DADIU"  ~ expr ~ expr ~ expr ~ semicolon }
  dadmu  = { ^"DADMU"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  dacliw = { ^"DACLIW" ~ expr ~ expr ~ expr ~ semicolon }
  dacqlc = { ^"DACQLC" ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  darea  = { ^"DAREA"  ~ expr ~ expr ~ expr ~ semicolon }
  dapew  = { ^"DAPEW"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  dapee  = { ^"DAPEE"  ~ expr ~ expr ~ expr ~ semicolon }
  dapea  = { ^"DAPEA"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  dapep  = { ^"DAPEP"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  daest  = { ^"DAEST"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  daepsm = { ^"DAEPSM" ~ expr ~ semicolon }
  epsmin = { ^"EPSMIN" ~ expr ~ semicolon }
  dafset = { ^"DAFSET" ~ expr ~ semicolon }
  dafilt = { ^"DAFILT" ~ expr ~ expr ~ semicolon }
  danotw = { ^"DANOTW" ~ expr ~ expr ~ semicolon }
  daflo  = { ^"DAFLO"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  cdflo  = { ^"CDFLO"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  dagmd  = { ^"DAGMD"  ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  danow   = { ^"DANOW"   ~ expr ~ expr ~ expr ~ semicolon }
  cdf2    = { ^"CDF2"    ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  cdnfds  = { ^"CDNFDS"  ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  cdnfda  = { ^"CDNFDA"  ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  cdnf    = { ^"CDNF"    ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  daran   = { ^"DARAN"   ~ expr ~ expr ~ semicolon }
  dacode = { ^"DACODE" ~ expr ~ expr ~ expr ~ semicolon }
  /// [ CORE ]
  scrlen = { ^"SCRLEN" ~ expr ~ semicolon }
  quit = { ^"QUIT" ~ expr ~ semicolon }
  os_call = { ^"OS" ~ expr ~ semicolon }
  substr = { ^"SUBSTR" ~ expr ~ expr ~ expr ~ variable_identifier ~ semicolon }
  velset = { ^"VELSET" ~ variable_identifier ~ expr ~ expr ~ semicolon }
  /// [ TIMING ]
  cpusec = { ^"CPUSEC" ~ variable_identifier ~ semicolon }
  /// [ VECTOR ACCESS ]
  velget = { ^"VELGET" ~ expr ~ expr ~ variable_identifier ~ semicolon }
  /// [ VECTOR MATH ]
  vedot = { ^"VEDOT" ~ expr ~ expr ~ variable_identifier ~ semicolon }
  veunit = { ^"VEUNIT" ~ expr ~ variable_identifier ~ semicolon }
  vezero = { ^"VEZERO" ~ variable_identifier ~ expr ~ expr ~ semicolon }
  /// [ TYPE CONVERSION ]
  stcre = { ^"STCRE" ~ expr ~ variable_identifier ~ semicolon }
  recst = { ^"RECST" ~ expr ~ expr ~ variable_identifier ~ semicolon }
  /// [ RANDOM ]
  reran = { ^"RERAN" ~ variable_identifier ~ semicolon }
  ranseed = { ^"RANSEED" ~ expr ~ semicolon }
  /// [ SYSTEM / UTILITY ]
  pwtime = { ^"PWTIME" ~ variable_identifier ~ semicolon }
  pnpro = { ^"PNPRO" ~ variable_identifier ~ semicolon }
  imunit = { ^"IMUNIT" ~ variable_identifier ~ semicolon }
  /// [ MATH ]
  linv = { ^"LINV" ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  ldet = { ^"LDET" ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  intpol = { ^"INTPOL" ~ variable_identifier ~ expr ~ semicolon }
  polval = { ^"POLVAL" ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  /// [ LINEAR ALGEBRA ]
  lev = { ^"LEV" ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  mblock = { ^"MBLOCK" ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  /// [ DA EVALUATION ]
  mtree = { ^"MTREE" ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
  /// [ SYSTEM UTILITIES ]
  sleepm = { ^"SLEEPM" ~ expr ~ semicolon }
  argget = { ^"ARGGET" ~ expr ~ variable_identifier ~ semicolon }
  memdpv = { ^"MEMDPV" ~ expr ~ expr ~ semicolon }
  memfre = { ^"MEMFRE" ~ variable_identifier ~ semicolon }
  memall = { ^"MEMALL" ~ variable_identifier ~ semicolon }
  memwrt = { ^"MEMWRT" ~ expr ~ semicolon }
  ltrue  = { ^"LTRUE"  ~ variable_identifier ~ semicolon }
  lfalse = { ^"LFALSE" ~ variable_identifier ~ semicolon }
  /// [ NUMERICAL / INTEGRATION ]
  lsline = { ^"LSLINE" ~ expr ~ expr ~ expr ~ variable_identifier ~ variable_identifier ~ semicolon }
  rkco = { ^"RKCO" ~ variable_identifier ~ variable_identifier ~ variable_identifier ~ variable_identifier ~ variable_identifier ~ semicolon }
  /// [ MEMORY SERIALIZATION ]
  /// WRITEM( c v c v v v ) — serialize variable into arrays
  writem = { ^"WRITEM" ~ expr ~ variable_identifier ~ expr ~ variable_identifier ~ variable_identifier ~ variable_identifier ~ semicolon }
  /// READM( v c c c c c ) — deserialize variable from arrays
  readm = { ^"READM" ~ variable_identifier ~ expr ~ expr ~ expr ~ expr ~ expr ~ semicolon }
/// [ INTRINSIC TYPES ]
  type = { "(" ~ inner_type ~ expr* ~ ")"}
  inner_type = {
    "RE" |
    "LO" |
    "VE" |
    "CM" |
    "ST" |
    "DA" |
    "CD" }

/// Assignment — RHS can be an expression or `.` (clear/reset)
assignment  = { variable_identifier ~ ":=" ~ (empty_literal | expr) ~ semicolon }
empty_literal = { "." }

// Expression parsing using Pratt parser
expr = { term ~ (infix_op ~ term)* }
term = _{ 
    not_expr |
    neg_expr |
    builtin_function | 
    boolean |
    number | 
    string |
    variable_identifier |
    "(" ~ expr ~ ")" }

// Unary negation (prefix minus)
neg_expr = { "-" ~ expr }

// Boolean literals
boolean = { ^"TRUE" | ^"FALSE" }

// NOT expression (prefix unary operator) - ROSY extension
// Use `!` directly adjacent to operand
not_expr = { "!" ~ (boolean | variable_identifier | "(" ~ expr ~ ")") }

// Infix operators
// Note: lte/gte must come before lt/gt to avoid `<=` being parsed as `<` then `=`
// We support both COSY syntax (= and #) and modern syntax (== and <>/!=)
infix_op    = _{ derive | extract | pow | mult | div | add | sub | concat | eq | neq | lte | gte | lt | gt | and_op | or_op }
derive      = { "%" }
extract     = { "|" }
pow         = { "^" }
add         = { "+" }
sub         = { "-" }
mult        = { "*" }
div         = { "/" }
concat      = { "&" }
eq          = { "==" | "=" }
neq         = { "<>" | "!=" | "#" }
lt          = { "<" }
gt          = { ">" }
lte         = { "<=" }
gte         = { ">=" }
and_op      = { ^"AND" }
or_op       = { ^"OR" }

variable_identifier = { variable_name ~ paren_group* ~ bracket_index? }
paren_group = { "(" ~ expr ~ ("," ~ expr)* ~ ")" }
bracket_index = { "[" ~ expr ~ ("," ~ expr)* ~ "]" }
variable_name  = @{ !keyword ~ (ASCII_ALPHANUMERIC | "_")+ }
number      = @{ "-"? ~ ASCII_DIGIT+ ~ ("." ~ ASCII_DIGIT+)? }
unit        = @{ ASCII_DIGIT+ }
constant    = @{ ASCII_DIGIT+ }
string      = { new_string | old_string }
new_string  = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" }
old_string  = @{ "\'" ~ ("\'\'" | !"\'" ~ ANY)* ~ "\'" }
semicolon   = { ";" }