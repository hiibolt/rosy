BEGIN;

PROCEDURE RUN;
    VARIABLE X_0 1;
    VARIABLE X_1 1;
    VARIABLE X_2 1;
    VARIABLE X_3 1;
    VARIABLE X_4 1;
    VARIABLE X_5 1;
    VARIABLE X_6 1;
    VARIABLE X_7 1;
    VARIABLE X_8 1;
    VARIABLE X_9 1;
    VARIABLE X_10 1;
    VARIABLE V_0 100;
    VARIABLE V_1 100;
    VARIABLE V_2 100;
    VARIABLE V_3 100;
    VARIABLE V_4 100;
    VARIABLE V_5 100;
    VARIABLE M_0 1;

    { Simple positive integer }
    X_0 := 42;
    WRITE 6 X_0;

    { Simple negative integer }
    X_1 := -7;
    WRITE 6 X_1;

    { Decimal number (pi) }
    X_2 := 3.14159;
    WRITE 6 X_2;

    { Zero }
    X_3 := 0;
    WRITE 6 X_3;

    { Small positive number }
    X_4 := 0.001;
    WRITE 6 X_4;

    { Large positive number }
    X_5 := 1234567890;
    WRITE 6 X_5;

    { Negative fraction }
    X_6 := -0.5;
    WRITE 6 X_6;

    { Very small number }
    X_7 := 0.000000001;
    WRITE 6 X_7;

    { Very large number }
    X_8 := 99999999999999;
    WRITE 6 X_8;

    { One }
    X_9 := 1;
    WRITE 6 X_9;

    { Negative one }
    X_10 := -1;
    WRITE 6 X_10;

    { Simple string }
    WRITE 6 'HELLO WORLD';

    { Empty-ish string }
    WRITE 6 'A';

    { Short vector (3 elements) }
    V_0 := 1;
    V_0 := V_0&2;
    V_0 := V_0&3;
    WRITE 6 V_0;

    { Vector with 5 elements (wrap boundary) }
    V_1 := 1;
    V_1 := V_1&2;
    V_1 := V_1&3;
    V_1 := V_1&4;
    V_1 := V_1&5;
    WRITE 6 V_1;

    { Vector with 7 elements (wraps to 2 lines) }
    V_2 := 1;
    V_2 := V_2&2;
    V_2 := V_2&3;
    V_2 := V_2&4;
    V_2 := V_2&5;
    V_2 := V_2&6;
    V_2 := V_2&7;
    WRITE 6 V_2;

    { Vector with 10 elements (wraps to 2 lines) }
    V_3 := 10;
    V_3 := V_3&20;
    V_3 := V_3&30;
    V_3 := V_3&40;
    V_3 := V_3&50;
    V_3 := V_3&60;
    V_3 := V_3&70;
    V_3 := V_3&80;
    V_3 := V_3&90;
    V_3 := V_3&100;
    WRITE 6 V_3;

    { Vector with large/small numbers }
    V_4 := 100000000;
    V_4 := V_4&0.0001;
    V_4 := V_4&-99999;
    V_4 := V_4&0.000001;
    WRITE 6 V_4;

    { Vector element extraction }
    V_5 := 11;
    V_5 := V_5&22;
    V_5 := V_5&33;
    WRITE 6 (V_5|1);

    { Mixed string and RE value }
    M_0 := 3.14159;
    WRITE 6 'VALUE: ' M_0;

ENDPROCEDURE;

RUN;
END;
