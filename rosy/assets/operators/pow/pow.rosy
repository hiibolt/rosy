BEGIN;
    VARIABLE (RE) LHS_0;
    VARIABLE (RE) RHS_0;
    VARIABLE (RE) RESULT_0;

    LHS_0 := 2;
    RHS_0 := 3;
    RESULT_0 := LHS_0 ^ RHS_0;
    WRITE 6 ST(RESULT_0);

    VARIABLE (VE) LHS_1;
    VARIABLE (RE) RHS_1;
    VARIABLE (VE) RESULT_1;

    LHS_1 := 1&2&3;
    RHS_1 := 2;
    RESULT_1 := LHS_1 ^ RHS_1;
    WRITE 6 ST(RESULT_1);

END;
