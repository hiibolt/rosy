{ ============================================================================
  libcosy/physics/elements_electric.rosy — Electric-field elements

  Status (post-M6): the full electric-element family is ported.
    * RF                                — analytical thin-lens cavity.
    * EQ / EH / EO / ED / EZ / E5 / EM /
      EMS                               — multipoles via FFELE.
    * EBEND / EC / ES / ECL / ESP / DC  — electrostatic deflectors and
                                          drift-cell helpers via FFELE.
    * CEG / CEL / CEA                   — Einzel-lens family via FFELE.
    * WC / WF                           — Wien-filter pair.

  RF Cavity (cosy.fox L3899-3916)
  -------------------------------
  RF(V, N, W, PHI, D) applies a thin-lens RF cavity to the active MAP
  (and the scratch MSC if rays are enabled). Inputs:
    * V : (RE 3 3) polynomial coefficients of the on-axis voltage
                   profile V(x, y) = sum_{ij} V[i,j] · x^(i-1) · y^(j-1)
    * N : (RE)     polynomial degree (N+1 terms per axis)
    * W : (RE)     RF frequency [Hz]
    * PHI: (RE)    RF phase at the longitudinal reference [degrees]
    * D : (RE)     pole-tip aperture [m]

  The cavity is treated as a thin lens: time-of-flight T translates to
  a phase, the polynomial V evaluated at (x, y) gives the energy kick,
  and the post-kick momenta are scaled by the new-to-old momentum ratio.
  ============================================================================ }

BEGIN;

INCLUDE '../globals.rosy';

{ ----- RF: thin-lens RF cavity (cosy.fox L3899-3916) ----------------------
  Algorithm:
    1. Save EE0 = CONS(E0), PP0 = CONS(P0) (energy/momentum BEFORE kick).
    2. Compute VV0 = POLY(0, 0, V, N) · sin(PHI·DEGRAD) · 0.001 · Z0
       (the constant-axis kick at reference; .001 factor converts kV→MeV
       per cosy.fox's electrical convention; Z0 is the charge state).
    3. Update reference particle to E0+VV0 via RP — this rebuilds
       P0/V0/CHIM/CHIE for the new kinetic energy.
    4. Apply RFM to MAP and (if rays enabled) MSC.
    5. Reset axis state and refresh derived globals (UPDATE 0 1 — the
       second 1 says rays were touched).

  RFM operates per-component:
    T  := M[5] · (-PP0/EE0/CLIGHT)        time-of-flight at origin
    VV := POLY(M[1], M[3], V, N) · sin(W·2π·T + PH) · (1+M[8]) · .001 · Z0
    M[2] := M[2] · PP0/CONS(P0)            scale x' to new momentum
    M[4] := M[4] · PP0/CONS(P0)            scale y' (only for ND>1)
    M[5] := T · (-CONS(E0)/CONS(P0)) · CLIGHT     restate t-of-flight
    M[6] := (M[6] + (VV-CONS(VV0))/EE0) / (1 + CONS(VV0)/EE0)   energy

  Pre-conditions: RP must have been called (LRP=1) and the new-energy
  check (CONS(E0)<1E-10 → "RF too high") guards against runaway. }
PROCEDURE RF V (RE 3 3) N (RE) W (RE) PHI (RE) D (RE);
  VARIABLE (RE) PP0;
  VARIABLE (RE) EE0;
  VARIABLE (RE) VV0;
  VARIABLE (RE) PH;

  PROCEDURE RFM M (DA 8);
    VARIABLE (DA) T;
    VARIABLE (DA) VV;
    T := M[5]*(-PP0/EE0/CLIGHT);
    VV := POLY_DA(M[1], M[3], V, N)*SIN(W*2*PI*T + PH)*(1 + M[8])*0.001*Z0;
    M[2] := M[2]*PP0/CONS(P0);
    IF ND > 1;
      M[4] := M[4]*PP0/CONS(P0);
    ENDIF;
    IF ND > 2;
      M[5] := T*(-CONS(E0)/CONS(P0))*CLIGHT;
      M[6] := (M[6] + (VV - VV0)/EE0)/(1 + VV0/EE0);
    ENDIF;
  ENDPROCEDURE;

  IF LRP # 1;
    WRITE 6 ' *** ERROR, call RP before RF';
    QUIT 0;
  ENDIF;
  PP0 := CONS(P0);
  EE0 := CONS(E0);
  PH := PHI*DEGRAD;
  VV0 := POLY(0, 0, V, N)*SIN(PH)*0.001*CONS(Z0);
  RP CONS(E0)+VV0 CONS(M0) CONS(Z0);
  IF CONS(E0) < 1E-10;
    WRITE 6 ' *** RF TOO HIGH';
    QUIT 0;
  ENDIF;
  RFM MAP;
  IF NRAY # 0;
    UMS;
    RFM MSC;
  ENDIF;
  LOCSET 0 0 0 0 0 0;
  DR := D;
  CE := 'RF';
  UPDATE 0 1;
ENDPROCEDURE;

{ ----- M6.4: SIELE-driven electric multipoles (cosy.fox L3724-3759) -----
  Parallel to the magnetic multipoles but with negative MPOL (identifying
  them as electric in POTFLD's POTS path) and PPOL holding voltages
  (kV) rather than fields (T). All delegate to FFELE which uses LFR=0
  for libcosy v1 (no fringe field).

  EQ = electric quadrupole, EH = electric sextupole (hexapole),
  EO = electric octupole, ED = electric decapole, EZ = electric
  dodecapole. E5 bundles the 5 lowest electric multipoles into one
  call. EM/EMS are array-of-strengths normal/skew forms.              }
PROCEDURE EQ L (RE) VV (RE) D (RE);
  NPOL := 1;
  PPOL[1] := VV/D/D + 0*DD[1];
  MPOL[1] := -2;
  LOFF := 1;
  FFELE L D 0 1 2 'EQ';
ENDPROCEDURE;

PROCEDURE EH L (RE) VV (RE) D (RE);
  NPOL := 1;
  PPOL[1] := VV/D/D/D + 0*DD[1];
  MPOL[1] := -3;
  LOFF := 1;
  FFELE L D 0 1 2 'EH';
ENDPROCEDURE;

PROCEDURE EO L (RE) VV (RE) D (RE);
  NPOL := 1;
  PPOL[1] := VV/D/D/D/D + 0*DD[1];
  MPOL[1] := -4;
  LOFF := 1;
  FFELE L D 0 1 2 'EO';
ENDPROCEDURE;

PROCEDURE ED L (RE) VV (RE) D (RE);
  NPOL := 1;
  PPOL[1] := VV/D/D/D/D/D + 0*DD[1];
  MPOL[1] := -5;
  LOFF := 1;
  FFELE L D 0 1 2 'ED';
ENDPROCEDURE;

PROCEDURE EZ L (RE) VV (RE) D (RE);
  NPOL := 1;
  PPOL[1] := VV/D/D/D/D/D/D + 0*DD[1];
  MPOL[1] := -6;
  LOFF := 1;
  FFELE L D 0 1 2 'EZ';
ENDPROCEDURE;

{ E5: 5-pole electric bundle (cosy.fox L3739-3745). }
PROCEDURE E5 L (RE) VQ (RE) VH (RE) VO (RE) VD (RE) VZ (RE) D (RE);
  NPOL := 5;
  PPOL[1] := VQ/D/D + 0*DD[1];                MPOL[1] := -2;
  PPOL[2] := VH/D/D/D + 0*DD[1];              MPOL[2] := -3;
  PPOL[3] := VO/D/D/D/D + 0*DD[1];            MPOL[3] := -4;
  PPOL[4] := VD/D/D/D/D/D + 0*DD[1];          MPOL[4] := -5;
  PPOL[5] := VZ/D/D/D/D/D/D + 0*DD[1];        MPOL[5] := -6;
  LOFF := 1;
  FFELE L D 0 1 2 'E5';
ENDPROCEDURE;

{ EM: arbitrary normal electric multipole array (cosy.fox L3747-3751). }
PROCEDURE EM L (RE) VA (RE 5) NVA (RE) D (RE);
  VARIABLE (RE) I;
  VARIABLE (DA) DP;
  DP := 1/D + 0*DD[1];
  LOOP I 1 NVA;
    DP := DP/D;
    PPOL[I] := VA[I]*DP;
    MPOL[I] := -(I+1);
  ENDLOOP;
  LOFF := 1;
  NPOL := NVA;
  FFELE L D 0 1 2 'EM';
ENDPROCEDURE;

{ ----- M6.7: EBEND — electrostatic combined-function deflector (cosy.fox L3761-3794)
  EBEND(R, PHI, D, N, NT, CI) is the electrostatic counterpart of the
  magnetic BEND. R is the bending radius (sets the dipole electric
  field component), PHI is the bend angle (radians), D is the aperture,
  N is an array of higher-multipole strengths, NT is the count, CI is
  the element-name string.

  libcosy v1 supports LFR=0 (no fringe field) only. cosy.fox's LFR=2.5/3
  paths (high-precision soft-edge fringe) need NSDP=-11..-13 (electric
  bend Cartesian field modes) which are deferred.

  Algorithm (LFR=0):
    1. Build PPOL[1] = CHIE/R/1000 (dipole electric, kV/m → MeV scaling).
    2. Build PPOL[I+1] = -PPOL[1] · N[I] / R^I / (I+1) for I=1..NT
       (multipole components, scaled by the radius geometry).
    3. Set MPOL[I] = -I (electric labels).
    4. SIELE R*PHI D — integrate across arc length R·PHI.
    5. LOCSET with curved-axis update.                                 }
PROCEDURE EBEND R (RE) PHI (RE) D (RE) N_ARR (RE 16) NT (RE) CI (ST);
  VARIABLE (RE) RPP;
  VARIABLE (RE) I;
  CE := CI;
  DR := D;
  LOFF := 2;
  IF R < 0;
    WRITE 6 ' *** ERROR in EBEND, negative radius';
    QUIT 0;
  ELSEIF PHI < 0;
    WRITE 6 ' *** ERROR in EBEND, negative angle';
    QUIT 0;
  ENDIF;
  IF LFR = 0;
    NPOL := NT + 1;
    PPOL[1] := CONS(CHIE)/R/1000 + 0*DD[1];
    RPP := 1;
    LOOP I 1 NT;
      RPP := RPP*R;
      PPOL[I+1] := -CONS(CHIE)/R/1000*N_ARR[I]/RPP/(I+1) + 0*DD[1];
    ENDLOOP;
    LOOP I 1 NPOL;
      MPOL[I] := -I;
    ENDLOOP;
    SIELE R*PHI D;
    LOCSET R*(COS(PHI)-1) R*SIN(PHI) PHI R*PHI 0 0;
    UPDATE 1 1;
  ELSEIF (LFR = 3) OR (LFR = 2.5);
    { LFR=3 / 2.5: high-precision soft-edge fringe (cosy.fox L3774-3791).
      NSDP=-11 routes through POTXZ/FIELDXZ → BENDIST IC=-1. PPOL is
      laid out with the bend-radius geometry encoded for BENDIST.       }
    VARIABLE (RE) LDL_LOCAL;
    VARIABLE (RE) NMULT_REAL;
    VARIABLE (DA 8) MS_EBEND;
    VARIABLE (DA 3 3) SM_EBEND;
    VARIABLE (RE) NEG_LDL_E;
    VARIABLE (RE) ARC_TOTAL;
    VARIABLE (RE) STEP_MIN_E;
    VARIABLE (RE) STEP_MID_E;
    VARIABLE (RE) STEP_MAX_E;
    NSDP := -11;
    LOOP I 1 36;
      PPOL[I] := 0*DD[1];
    ENDLOOP;
    PPOL[1]  := CONS(CHIE)/R/1000 + 0*DD[1];
    PPOL[2]  := -R + 0*DD[1];
    PPOL[4]  := D + 0*DD[1];
    PPOL[8]  := 1 + 0*DD[1];
    PPOL[9]  := R*(COS(PHI)-1) + 0*DD[1];
    PPOL[10] := R*SIN(PHI) + 0*DD[1];
    PPOL[11] := CONS(PPOL[9]) + SIN(PHI) + 0*DD[1];
    PPOL[12] := CONS(PPOL[10]) - COS(PHI) + 0*DD[1];
    IF NT > 16;
      WRITE 6 ' --- WARNING in EBEND, NT > 16 truncated';
    ENDIF;
    NMULT_REAL := MIN(NT, 16);
    PPOL[20] := NMULT_REAL + 0*DD[1];
    LOOP I 1 NMULT_REAL;
      PPOL[20+I] := N_ARR[I]/(I+1) + 0*DD[1];
    ENDLOOP;
    LDL_LOCAL := 10*D;
    NEG_LDL_E := -LDL_LOCAL;
    ARC_TOTAL := R*PHI + 2*LDL_LOCAL;
    STEP_MIN_E := MIN(R/10000, D/200);
    STEP_MID_E := MIN(R/20, D);
    STEP_MAX_E := MIN(R, 7*D);
    LOCSET 0 NEG_LDL_E 0 0 0 0;
    IF LFR = 3;
      LOCSET R*(COS(0.5*PHI)-1) R*SIN(0.5*PHI) 0.5*PHI 0.5*R*PHI 0 0;
      SDELEREF 0.5*R*PHI NEG_LDL_E D/200 D 7*D D;
    ENDIF;
    UMS;
    DLACT MSC NEG_LDL_E;
    SNM MSC MS_EBEND;
    SSNM SSCR SM_EBEND;
    VARIABLE (RE) XLOC_TMP;
    VARIABLE (RE) ZLOC_TMP;
    VARIABLE (RE) PLOC_TMP;
    XLOC_TMP := XLOC;
    ZLOC_TMP := ZLOC;
    PLOC_TMP := PLOC;
    LOCSET XLOC_TMP ZLOC_TMP PLOC_TMP 0 0 0;
    SDELE 0 ARC_TOTAL STEP_MIN_E STEP_MID_E STEP_MAX_E D;
    UPDATEMAP MSC MS_EBEND MSC SSCR SM_EBEND SSCR;
    DLACT MSC NEG_LDL_E;
    SLOC := R*PHI;
    XLOC := XLOC + LDL_LOCAL*SIN(PLOC);
    ZLOC := ZLOC - LDL_LOCAL*COS(PLOC);
    UPDATE 1 1;
  ELSE;
    WRITE 6 ' *** ERROR in EBEND, only LFR=0 / 3 / 2.5 supported in libcosy v1';
    QUIT 0;
  ENDIF;
ENDPROCEDURE;

{ ----- EC / ES / ECL / ESP — electrostatic deflector wrappers (cosy.fox L3796-3814)
  EC takes user-supplied N array; ES bundles 5 scalars; ECL/ESP build
  the canonical cylindrical / spherical N arrays before delegating to
  EBEND.                                                                }
PROCEDURE EC R (RE) PHID (RE) D (RE) N_ARR (RE 16) NT (RE);
  EBEND R PHID*DEGRAD D N_ARR NT 'EC';
ENDPROCEDURE;

PROCEDURE ES R (RE) PHID (RE) D (RE)
            N1 (RE) N2 (RE) N3 (RE) N4 (RE) N5 (RE);
  VARIABLE (RE 16) N_VEC;
  VARIABLE (RE) I;
  N_VEC[1] := N1; N_VEC[2] := N2; N_VEC[3] := N3; N_VEC[4] := N4; N_VEC[5] := N5;
  LOOP I 6 16;
    N_VEC[I] := 0;
  ENDLOOP;
  EBEND R PHID*DEGRAD D N_VEC 5 'ES';
ENDPROCEDURE;

{ ECL: cylindrical deflector — N[I] = (-1)^(I+1) for all I up to MAX(5,NO+1). }
PROCEDURE ECL R (RE) PHID (RE) D (RE);
  VARIABLE (RE 16) N_VEC;
  VARIABLE (RE) I;
  VARIABLE (RE) NT_LOCAL;
  NT_LOCAL := MAX(5, NO+1);
  LOOP I 1 NT_LOCAL;
    N_VEC[I] := 1;
  ENDLOOP;
  LOOP I 2 NT_LOCAL 2;
    N_VEC[I] := -1;
  ENDLOOP;
  EBEND R PHID*DEGRAD D N_VEC NT_LOCAL 'ECL';
ENDPROCEDURE;

{ ESP: spherical deflector — N[I] = (-1)^(I+1) · (I+1). }
PROCEDURE ESP R (RE) PHID (RE) D (RE);
  VARIABLE (RE 16) N_VEC;
  VARIABLE (RE) I;
  VARIABLE (RE) NT_LOCAL;
  NT_LOCAL := MAX(5, NO+1);
  LOOP I 1 NT_LOCAL;
    N_VEC[I] := I+1;
  ENDLOOP;
  LOOP I 2 NT_LOCAL 2;
    N_VEC[I] := -(I+1);
  ENDLOOP;
  EBEND R PHID*DEGRAD D N_VEC NT_LOCAL 'ESP';
ENDPROCEDURE;

{ ----- M6.7+: DC + CEG — accelerator + Gaussian electric lens -----
  DC (cosy.fox L3893-3897): static homogeneous E-field accelerator
  with potential P = -V/L · s. Uses NSDP=11, MPOL=-20 (skew/no-mult
  marker), LOFF=1. SDELE drives the integration over [0, L].

  CEG (cosy.fox L3872-3874): Gaussian electric lens. Uses NSDP=3
  (Gaussian s-profile), DSDED for the negative-drift wrap.            }
PROCEDURE DC V_VOLT (RE) D_AP (RE) L (RE);
  NPOL := 1;
  MPOL[1] := -20;
  NSDP := 11;
  LOFF := 1;
  CE := 'DC';
  PPOL[1] := -V_VOLT/L + 0*DD[1];
  LOCSET 0 0 0 0 0 0;
  SDELE 0 L 1E-4*D_AP D_AP 10*D_AP D_AP;
  UPDATE 1 1;
ENDPROCEDURE;

PROCEDURE CEG V_VOLT (RE) D_AP (RE);
  NPOL := 1;
  PPOL[1] := V_VOLT + 0*DD[1];
  MPOL[1] := -20;
  NSDP := 3;
  CE := 'CEG';
  LOFF := 1;
  DSDED 5*D_AP 0 1E-4*D_AP D_AP 10*D_AP D_AP;
ENDPROCEDURE;

{ ----- CEL — three-tube electric lens (cosy.fox L3876-3884) -----
  V/D characterise the central tube; L is the gap length, C the tube
  spacing. Uses NSDP=6 (three-tube cosh/log profile) with the
  characteristic-length scaling DR := D/O where O = 1.315 (Jiye
  empirical constant).                                                }
PROCEDURE CEL V_VOLT (RE) D_AP (RE) L_GAP (RE) C_SPACE (RE);
  VARIABLE (RE) O;
  O := 1.315;
  NPOL := 1;
  MPOL[1] := -20;
  NSDP := 6;
  DR := D_AP/O;
  LOFF := 1;
  CE := 'CEL';
  PPOL[1] := -V_VOLT/(2*O/D_AP*C_SPACE) + 0*DD[1];
  PPOL[2] := O*L_GAP/2/D_AP + 0*DD[1];
  PPOL[3] := O*(C_SPACE+L_GAP/2)/D_AP + 0*DD[1];
  DSDED 5*D_AP+C_SPACE+L_GAP/2 0 1E-4*D_AP D_AP 10*D_AP D_AP/O;
ENDPROCEDURE;

{ ----- CEA — three-aperture electric einzel lens (cosy.fox L3886-3891) -----
  V/D/L/C parameters as for CEL. Uses NSDP=9 (atan-product profile).
  DSDED extends 15D + C + L/2 in each direction since the atan field
  decay is slower than the cosh of CEL.                                }
PROCEDURE CEA V_VOLT (RE) D_AP (RE) L_GAP (RE) C_SPACE (RE);
  NPOL := 1;
  MPOL[1] := -20;
  NSDP := 9;
  LOFF := 1;
  CE := 'CEA';
  PPOL[1] := V_VOLT/(PI*C_SPACE) + 0*DD[1];
  PPOL[2] := L_GAP/2 + 0*DD[1];
  PPOL[3] := C_SPACE+L_GAP/2 + 0*DD[1];
  DSDED 15*D_AP+C_SPACE+L_GAP/2 0 1E-4*D_AP D_AP 10*D_AP D_AP;
ENDPROCEDURE;

{ ----- WC — combined-function Wien filter (cosy.fox L3816-3822) -----
  WC(RE_RAD, RM_RAD, L, D, NE, NM, NT) sets up a Wien filter with
  electric bend radius RE_RAD, magnetic bend radius RM_RAD, length L,
  aperture D. NE/NM are normal-multipole strength arrays for the
  electric / magnetic components beyond dipole (NT entries each).

  PPOL setup:
    PPOL[1] = -CHIE/RE_RAD/1000  (electric dipole, MPOL=-1)
    PPOL[2] = +CHIM/RM_RAD       (magnetic dipole, MPOL=+1)
    PPOL[2+I]   = PPOL[1]·NE[I]/(I+1)   (elec multipole I+1, MPOL=-(I+1))
    PPOL[2+I+NT]= PPOL[2]·NM[I]         (mag  multipole I+1, MPOL=+(I+1))

  H_LOCAL = 1/RM - 1/RE  is the net curvature for the LOCSET.

  libcosy v1: only LFR=0 path works (LFR≠0 would need POTXZ NSDP=-1/-2
  for bend-element Cartesian fringe fields, deferred).               }
PROCEDURE WC RE_RAD (RE) RM_RAD (RE) L (RE) D_AP (RE)
            NE_ARR (RE 16) NM_ARR (RE 16) NT (RE);
  VARIABLE (RE) I;
  VARIABLE (RE) H_LOCAL;
  VARIABLE (RE) PE_DIP;
  VARIABLE (RE) PM_DIP;
  VARIABLE (RE) NEG1;
  VARIABLE (RE) NEG2;
  NEG1 := -1;
  NEG2 := -2;
  NPOL := 2 + 2*NT;
  PE_DIP := -CONS(CHIE)/RE_RAD/1000;
  PM_DIP := CONS(CHIM)/RM_RAD;
  PPOL[1] := PE_DIP + 0*DD[1];
  MPOL[1] := -1;
  PPOL[2] := PM_DIP + 0*DD[1];
  MPOL[2] := 1;
  LOOP I 1 NT;
    PPOL[2+I] := PE_DIP*NE_ARR[I]/(I+1) + 0*DD[1];
    MPOL[2+I] := -I-1;
    PPOL[2+I+NT] := PM_DIP*NM_ARR[I] + 0*DD[1];
    MPOL[2+I+NT] := I+1;
  ENDLOOP;
  LOFF := 2;
  H_LOCAL := 1/RM_RAD - 1/RE_RAD;
  FFELE L D_AP H_LOCAL NEG1 NEG2 'WC';
ENDPROCEDURE;

{ ----- WF — homogeneous Wien filter (cosy.fox L3824) -----
  Convenience wrapper: WC with NT=0 (no multipoles).                   }
PROCEDURE WF RE_RAD (RE) RM_RAD (RE) L (RE) D_AP (RE);
  VARIABLE (RE 16) NE_ZEROS;
  VARIABLE (RE 16) NM_ZEROS;
  VARIABLE (RE) I;
  LOOP I 1 16;
    NE_ZEROS[I] := 0;
    NM_ZEROS[I] := 0;
  ENDLOOP;
  WC RE_RAD RM_RAD L D_AP NE_ZEROS NM_ZEROS 0;
ENDPROCEDURE;

{ EMS: skew electric multipole — VA normal, VS skew (cosy.fox L3753-3759). }
PROCEDURE EMS L (RE) VA (RE 5) VS (RE 5) NV_PARAM (RE) D (RE);
  VARIABLE (RE) I;
  VARIABLE (DA) DP;
  DP := 1/D + 0*DD[1];
  LOOP I 1 NV_PARAM;
    DP := DP/D;
    PPOL[I] := VA[I]*DP;
    MPOL[I] := -(I+1);
  ENDLOOP;
  DP := 1/D + 0*DD[1];
  LOOP I 1 NV_PARAM;
    DP := DP/D;
    PPOL[I+NV_PARAM] := -VS[I]*DP*(I+1);
    MPOL[I+NV_PARAM] := -(I+1+20);
  ENDLOOP;
  LOFF := 1;
  NPOL := 2*NV_PARAM;
  FFELE L D 0 1 2 'EMS';
ENDPROCEDURE;

END;
