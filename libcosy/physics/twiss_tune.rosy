{ ============================================================================
  libcosy/physics/twiss_tune.rosy — Twiss / sigma-matrix / tune helpers

  cosy.fox L489-502 onwards. Beam-envelope and sigma-matrix utilities
  layered on top of the GT / DANF / NF stack.
  ============================================================================ }

BEGIN;

INCLUDE '../globals.rosy';

{ ----- SIGMA: beam sigma-matrix element (cosy.fox L489-502) ---------------
  SIGMA(I, J) returns the (I, J) element of the beam sigma matrix from
  the active MAP. Handles three cases:
    * I = J, I odd  → position-position variance (q_i^2 term)
    * I = J, I even → momentum-momentum variance (p_i^2 term)
    * |I - J| = 1, max(I, J) even → cross-correlation between conjugate
                                    position-momentum pair
  Other (I, J) combinations error out (cross-pair correlations vanish for
  uncoupled lattices).

  PHSP[i] are the per-coordinate phase-space scaling factors and PHSR[k]
  are the correlation coefficients between the k-th conjugate pair —
  both declared in globals.rosy and seeded by user code (typically zero
  initially in libcosy v1).                                               }
FUNCTION (RE) SIGMA I (RE) J (RE);
  VARIABLE (RE) K;
  IF (I = J) AND (INT(I/2) # I/2);
    SIGMA := SQR(PHSP[I]*ME(I, I)) + SQR(PHSP[I+1]*ME(I, I+1))
           + 2*PHSP[I]*PHSP[I+1]*PHSR[(I+1)/2]*ME(I, I)*ME(I, I+1);
  ELSEIF (I = J) AND (INT(I/2) = I/2);
    SIGMA := SQR(PHSP[I-1]*ME(I, I-1)) + SQR(PHSP[I]*ME(I, I))
           + 2*PHSP[I-1]*PHSP[I]*PHSR[I/2]*ME(I, I-1)*ME(I, I);
  ELSEIF (ABS(I - J) = 1) AND (INT(MAX(J, I)/2)*2 = MAX(J, I));
    K := MIN(I, J);
    SIGMA := SQR(PHSP[K])*ME(K, K)*ME(K+1, K)
           + SQR(PHSP[K+1])*ME(K, K+1)*ME(K+1, K+1);
    SIGMA := SIGMA
           + PHSP[K]*PHSP[K+1]*PHSR[(K+1)/2]*(ME(K, K)*ME(K+1, K+1)
                                              + ME(K, K+1)*ME(K+1, K));
  ELSE;
    WRITE 6 ' *** ERROR in SIGMA, wrong element';
    QUIT 0;
  ENDIF;
ENDFUNCTION;

{ ----- STW: set MAP from Twiss parameters (cosy.fox L1283-1288) -----------
  STW(I, MU, ALPHA, BETA, GAMMA) builds a single-plane Courant-Snyder map
  in the I-th phase-space pair (I=1, 2, or 3) of the active MAP, from the
  given tune (MU in radians) and Twiss alpha/beta/gamma. Useful for
  bootstrapping a known-Twiss linear lattice without integrating elements. }
PROCEDURE STW I (RE) MU (RE) ALPHA (RE) BETA (RE) GAMMA (RE);
  VARIABLE (RE) COSMU;
  VARIABLE (RE) SINMU;
  VARIABLE (RE) I1;
  VARIABLE (RE) I2;
  I1 := 2*I - 1;
  I2 := 2*I;
  COSMU := COS(MU);
  SINMU := SIN(MU);
  MAP[I1] := (COSMU + ALPHA*SINMU)*DD[I1] + BETA*SINMU*DD[I2];
  MAP[I2] := (COSMU - ALPHA*SINMU)*DD[I2] - GAMMA*SINMU*DD[I1];
ENDPROCEDURE;

{ ----- SE: symplectic-error norm of a map (cosy.fox L1290-1301) -----------
  SE(M) returns ‖J(M)^T · JJ · J(M) - JJ‖, the deviation of the linear part
  J(M) of map M from being symplectic. JJ is the canonical 2N×2N symplectic
  form. SE = 0 means M is exactly symplectic; small SE indicates numerical
  symplectic-violation of the order's truncation. Result is order-weighted
  via WABS / WAF.                                                           }
FUNCTION (RE) SE M (DA 8);
  VARIABLE (RE) I;
  VARIABLE (RE) J;
  VARIABLE (RE) K;
  VARIABLE (DA) X;
  VARIABLE (RE) Y;

  Y := -1;
  SE := 0;
  LOOP I 1 TWOND;
    LOOP J 1 TWOND;
      IF Y*(I-J) = 1;
        X := Y + 0*DD[1];
      ELSE;
        X := 0*DD[1];
      ENDIF;
      LOOP K 2 TWOND 2;
        X := X + DER(K-1, M[I])*DER(K, M[J]) - DER(K-1, M[J])*DER(K, M[I]);
      ENDLOOP;
      CO NOC-1;
      SE := SE + WABS(X, WAF);
      CO NOC+1;
    ENDLOOP;
    Y := -Y;
  ENDLOOP;
  SE := SE/TWOND/TWOND;
ENDFUNCTION;

{ ----- OE: spin-map orthogonality error (cosy.fox L1303-1315) -------------
  OE(A) = ‖A · A^T - I‖ + |det A - 1| for a 3×3 spin map A. Validates
  that A is a proper rotation: orthogonal AND determinant +1.            }
FUNCTION (RE) OE A (DA 3 3);
  VARIABLE (DA) X;
  VARIABLE (RE) I;
  VARIABLE (RE) J;
  VARIABLE (RE) K;

  OE := 0;
  LOOP I 1 3;
    LOOP J 1 3;
      IF I = J;
        X := -1 + 0*DD[1];
      ELSE;
        X := 0*DD[1];
      ENDIF;
      LOOP K 1 3;
        X := X + A[I, K]*A[J, K];
      ENDLOOP;
      OE := OE + WABS(X, WAF);
    ENDLOOP;
  ENDLOOP;
  X := A[1, 1]*(A[2, 2]*A[3, 3] - A[3, 2]*A[2, 3])
     - A[1, 2]*(A[2, 1]*A[3, 3] - A[3, 1]*A[2, 3])
     + A[1, 3]*(A[2, 1]*A[3, 2] - A[3, 1]*A[2, 2]);
  OE := OE/9 + WABS(X - 1, WAF);
ENDFUNCTION;

{ ----- SBE: set beam ellipsoid from emittances (cosy.fox L866-875) ----------
  SBE(EX, EY, ET) configures the beam phase-space ellipsoid (via SB) from
  three emittances — horizontal (EX), vertical (EY), and longitudinal (ET).
  For each plane, the ellipsoid axes (X, A) and correlation R are derived
  from the linear matrix elements of the active MAP, assuming the map is
  stable in that plane (|trace/2| < 1).

  Algorithm: per plane I = 1..ND,
    1. trace = ME(J, J) + ME(K, K)  where J=2I-1, K=2I.
    2. If |trace| < 2-1E-10 (stable): compute DUM scaling factor, then
       X = sqrt(DUM·|ME(J,K)|), A = sqrt(DUM·|ME(K,J)|),
       R = (ME(K,K)-ME(J,J))/2 · sign(ME(J,K)) / sqrt(|ME(J,K)·ME(K,J)|).
    3. Otherwise: zero out the plane and warn ("map unstable").
  Finally calls SB to install the ellipsoid into the global beam state. }
PROCEDURE SBE EX (RE) EY (RE) ET (RE);
  VARIABLE (RE 3) E_VEC;
  VARIABLE (RE) I; VARIABLE (RE) J; VARIABLE (RE) K;
  VARIABLE (RE) DUM;
  VARIABLE (RE 3) X_VEC;
  VARIABLE (RE 3) A_VEC;
  VARIABLE (RE 3) R_VEC;

  E_VEC[1] := EX; E_VEC[2] := EY; E_VEC[3] := ET;

  LOOP I 1 ND;
    K := 2*I;
    J := K - 1;
    IF ABS(ME(J, J) + ME(K, K)) < (2 - 1E-10);
      DUM := E_VEC[I]/PI/SQRT(1 - SQR(ME(J, J) + ME(K, K))/4);
      X_VEC[I] := SQRT(DUM*ABS(ME(J, K)));
      A_VEC[I] := SQRT(DUM*ABS(ME(K, J)));
      R_VEC[I] := (ME(K, K) - ME(J, J))/2*SIG(ME(J, K))
                  / SQRT(ABS(ME(J, K)*ME(K, J)));
    ELSE;
      X_VEC[I] := 0;
      A_VEC[I] := 0;
      R_VEC[I] := 0;
      WRITE 6 ' --- WARNING in SBE, map unstable';
    ENDIF;
  ENDLOOP;

  SB X_VEC[1] A_VEC[1] R_VEC[1] X_VEC[2] A_VEC[2] R_VEC[2]
     X_VEC[3] A_VEC[3] R_VEC[3] 0 0;
ENDPROCEDURE;

END;
