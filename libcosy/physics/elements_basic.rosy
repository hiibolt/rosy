{ ============================================================================
  libcosy/physics/elements_basic.rosy — Basic / drift-class elements

  Initial port of cosy.fox L2890-2932. Starts with the drift element DL,
  built on DLACT (the underlying field-free advance of a DA-array map).

  Status (post-M6 + M16):
    * DLACT / DL / PS / CB land here. SDELE / SDELEREF / DSDED / SIELE /
      FFELE / GE / SYSCLM / RSM are now in field_potential.rosy after M6.
    * DL does not yet route through UPDATE (so SPOS / LTRA / GTRA don't
      advance through DL the cosy.fox way). M16.5 candidate refactor.
  ============================================================================ }

BEGIN;

INCLUDE '../globals.rosy';

{ ----- Drift action on a DA-array map (cosy.fox L2892-2900) ---------------
  DLACT advances the DA-array ARR by a drift of length L. ARR is
  modified in place: position components ARR[1, 3, 5] pick up
  L · momentum / γ-corrected step, where γ comes from the canonical
  energy / mass relations through ETA and the canonical-momentum
  components ARR[2], ARR[4], ARR[6], ARR[7].

  LKC = 0 → use the full kinematic correction (default)
  LKC = 1 → use the linearized version (faster, less accurate at
            large transverse momenta)                                    }
PROCEDURE DLACT ARR L (RE);
  VARIABLE (DA) LP0PZ;
  LP0PZ := CONS(ETA) + 0*DA(1);
  LP0PZ := (1 + ARR[6])*(2*(1 + ARR[7]) + (1 + ARR[6])*LP0PZ)/(2 + LP0PZ);
  IF LKC = 0;
    LP0PZ := L*ISRT(LP0PZ - SQR(ARR[2]) - SQR(ARR[4]));
  ELSEIF LKC = 1;
    LP0PZ := L*ISRT(LP0PZ);
  ENDIF;
  ARR[1] := ARR[1] + LP0PZ*ARR[2];
  IF ND > 1;
    ARR[3] := ARR[3] + LP0PZ*ARR[4];
  ENDIF;
  IF ND > 2;
    LP0PZ := (1 + ARR[7] + (1 + ARR[6])*CONS(ETA))*LP0PZ/(1 + CONS(ETA)) - L;
    ARR[5] := ARR[5] - LP0PZ*(1 + CONS(ETA))/(2 + CONS(ETA));
  ENDIF;
ENDPROCEDURE;

{ ----- Field-free drift (cosy.fox L2902-2905) -----------------------------
  Propagates the active MAP and the scratch MSC through a drift of length
  L. cosy.fox additionally calls LOCSET (axis-display offset) and UPDATE
  (graphics + ray flow); both are graphics-only and skipped.             }
PROCEDURE DL L (RE);
  IF LUM # 1;
    WRITE 6 ' *** ERROR, call UM before DL';
    QUIT 0;
  ENDIF;
  DLACT MAP L;
  UMS;
  DLACT MSC L;
  LOCSET 0 L 0 L 0 0;
  DR := 0;
  UPDATE 0 1;
ENDPROCEDURE;

{ ----- PS: Poincaré-section marker (cosy.fox L2907-2908) -----------------
  PS(D) marks a Poincaré-section boundary in the beamline. It sets the
  global drift-radius scalar DR := D, zeros the local Cartesian axis
  state via LOCSET, and calls UPDATE 0 0 to refresh derived state.

  In cosy.fox this also triggers a graphics display of the section
  contents. libcosy v1 has no graphics, so PS is purely a state
  marker — useful for users who want to break a long element chain
  into "stations" without actually advancing the map.                    }
PROCEDURE PS D (RE);
  DR := D;
  LOCSET 0 0 0 0 0 0;
  UPDATE 0 0;
ENDPROCEDURE;

{ ----- CB: change bending direction (cosy.fox L3098-3106) -----------------
  CB negates the x-position and x-momentum components of the active MAP,
  RAY (per-particle bundle), RSC (snapshot), and the spin row SPNR[1,*]
  + SPI[1] + SSC[1]. Used to flip a magnet's bending direction (e.g.
  before a RIGHT-bend vs. a LEFT-bend in a chicane). LCB tracks the
  cumulative sign so subsequent UPDATE calls know which frame applies. }
PROCEDURE CB;
  VARIABLE (RE) I;
  IF LUM = 0;
    WRITE 6 ' *** ERROR, call UM before CB';
    QUIT 0;
  ENDIF;
  MAP[1] := -MAP[1];
  MAP[2] := -MAP[2];
  RAY[1] := -RAY[1];
  RAY[2] := -RAY[2];
  RSC[1] := -RSC[1];
  RSC[2] := -RSC[2];
  IF LSPN = 1;
    LOOP I 1 3;
      SPNR[1, I] := -SPNR[1, I];
    ENDLOOP;
    SPI[1] := -SPI[1];
    SSC[1] := -SSC[1];
  ENDIF;
  LCB := -LCB;
ENDPROCEDURE;

END;
