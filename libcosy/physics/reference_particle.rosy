{ ============================================================================
  libcosy/physics/reference_particle.rosy — Reference particle + setup

  Ports the lightweight setup primitives from cosy.fox L393-444, L2319-2329:

    DEF       — physical constants (AMU, EZERO, CLIGHT, AMUMEV, PI, DEGRAD)
    CO  NNO   — change computational order (writes NOC + DANOT)
    KC  I     — kinematic-correction flag (LKC), warns on disable
    WAS I     — wedge-computation flag (LWA = -I)
    FR  I     — fringe-field mode flag (LFR), conditionally bootstraps FD2
    SB ...    — set phase-space widths (PHSP / PHSR + LPS guard)
    SP ...    — set parameter widths (PARS)
    PARA(I)   — DA-coordinate helper for parameter dependence

  Deferred to a later milestone (need correct DA-typed RAY / MAP / DD
  globals plus DAINI ordering — they're a tight cluster):

    OV  ORD NND NNP    — order / dimension / parameter setup, the gateway
                          procedure every cosy.fox script calls first
    CR                 — clear rays (touches RAY / RSC / SPI / SSC, and
                          treats RAY(I) as a column slice of a 10001×8
                          array — needs slice-via-partial-index semantics)
    UM / UMS           — unity map and unity scratch map (touch MAP / MSC
                          which must be (DA 8) and accept 0*DD(1) idioms)
    RP / RPR / RPM /
    RPP / RPE / RPPI /
    RPMU / RPS         — reference-particle setup variants (depend on OV)

  These will be the focus of the next milestone (M3.5 / M4) along with
  fixes to globals.rosy for the few RE/DA mis-typings that block them.
  ============================================================================ }

BEGIN;

INCLUDE '../globals.rosy';

{ ----- Physical constants (cosy.fox L393-398) -----------------------------
  cosy.fox additionally calls `LTRUE TRUE; LFALSE FALSE` to seed two of
  COSY's RE-as-bool globals; ROSY reserves TRUE / FALSE as keywords (LO
  literals) so those globals don't exist here, and the corresponding lines
  are intentionally omitted. Code that previously branched on `IF X = TRUE`
  is ported as `IF X = 1` (or stays as `IF X` when TRUE was a bare guard). }
PROCEDURE DEF;
  AMU    := 1.66053873D-27;
  EZERO  := 1.602176462D-19;
  CLIGHT := 2.99792458D8;
  AMUMEV := AMU * SQR(CLIGHT) / EZERO * 1D-6;
  PI     := 3.1415926535897932384626433832795028842;
  DEGRAD := PI / 180;
  ESET 1E-10;
  WSET 0.1;
  DSET 1E-16;
ENDPROCEDURE;

{ ----- Computational-order change (cosy.fox L405) ------------------------- }
PROCEDURE CO NNO (RE);
  NOC := NNO;
  DANOT NOC;
ENDPROCEDURE;

{ ----- Order / dimension / parameter setup (cosy.fox L406-426) ------------
  The single most important entry point in libcosy: every cosy.fox script
  starts with `OV order ND NP;` to set the phase-space order, dimension,
  and parameter count. Initializes the DA system (DAINI), seeds the DD
  scratch buffer with basis variables DA(1)..DA(NV), sets every flow-
  control flag to its default, and chains DEF → FD for constants and
  fringe-field defaults.

  cosy.fox additionally calls CR at the bottom to clear ray buffers; CR
  needs partial-index slice semantics on RAY / RSC / SPI / SSC that ROSY
  doesn't yet provide, so the corresponding scalar flags (NRAY, NSPN,
  LCR, LENV) are zeroed inline here. The array-clearing CR will land
  alongside ray_io.rosy in M4.                                             }
PROCEDURE OV ORD (RE) NND (RE) NNP (RE);
  VARIABLE (RE) I;
  IF NND > 3;     WRITE 6 ' *** ERROR in OV, ND > 3 '; QUIT 0;
  ELSEIF NND < 0; WRITE 6 ' *** ERROR in OV, ND < 0 '; QUIT 0;
  ELSEIF NNP < 0; WRITE 6 ' *** ERROR in OV, NP < 0 '; QUIT 0;
  ENDIF;
  NO := ORD; ND := NND; TWOND := 2*ND; NP := NNP; NV := TWOND + NP;
  IF LWA < 0; LWA := -LWA; NV := NV + 1; ENDIF;
  IF NV > 40;
    IF LWA = 0;
      WRITE 6 '*** ERROR in OV, 2*ND+NP > 40 ';
    ELSEIF LWA # 0;
      WRITE 6 '*** ERROR in OV, 2*ND+NP > 39 ';
    ENDIF;
    QUIT 0;
  ENDIF;
  DEF;
  IF ND = 0;
    DAINI NO NV 0 NM1;
  ELSE;
    DAINI NO+1 MAX(NV, 3) 0 NM1;
  ENDIF;
  NM2 := NMON(NO, TWOND + NP);
  NM3 := NMON(NO + 1, 3);
  NMP := NMON(NO, NP);
  { Clear the DD slots above NV. Bare RE 0 would mismatch the DA-typed
    DD; use `0*DA(1)` so the assignment is in DA-space. }
  LOOP I NV+1 20;
    DD[I] := 0*DA(1);
  ENDLOOP;
  SVSCR;
  LSCR := MAX(50000, LSCR);
  LSCR := MAX(LSCR, 2*NM1);
  SCRLEN LSCR;
  LSCT := 50000;
  { Seed DD with the basis DA variables DA(1)..DA(MAX(NV, 3)). }
  LOOP I 1 MAX(NV, 3);
    DD[I] := DA(I);
  ENDLOOP;
  DSET 1E-16;
  CO NO;
  { Default flow-control state — every flag off / unset, with LSYS / LCE /
    LAX / LCB pre-armed to enable the picture / energy-grid / axis update
    paths once their state machines start firing. }
  LOV := 1;     LRP := 0;     LUM := 0;     LPI := 0;
  LCB := 1;     LPG := 0;     LPS := 0;     LM  := 0;
  LFR := 0;     LFR2 := 0;
  LENV := 0;    LSYS := 1;    LCE := 1;     LAX := 1;
  LTRR := 0;    LTRI := 0;
  LTRPRAY := 0; LTRPSPI := 0;
  { CR-equivalent scalar resets (the array clears defer to M4 ray_io). }
  NRAY := 0; NSPN := 0; LCR := 0;
  NRAYTRA0 := 251;
  NRAYTRA := NRAY;
  FD;
ENDPROCEDURE;

{ ----- Kinematic-correction flag (cosy.fox L2324-2326) -------------------- }
PROCEDURE KC I (RE);
  LKC := I;
  IF I = 1;
    WRITE 6 ' --- WARNING in KC, effects only in ODE and DLACT';
  ENDIF;
ENDPROCEDURE;

{ ----- Wedge-computation flag (cosy.fox L2328-2329) ----------------------- }
PROCEDURE WAS I (RE);
  LWA := -I;
ENDPROCEDURE;

{ ----- Fringe-field mode (cosy.fox L2319-2322) ----------------------------
  The conditional FD2 bootstrap is suppressed here because FD2 lives in
  the deferred symplectic-scaling block (FC2/FD2/SYSCFL). When FD2 lands,
  the inner branch becomes `IF (I < 3) AND (I > 0) AND (LFR2 = 0); FD2;
  LFR2 := 1; ENDIF;`.                                                     }
PROCEDURE FR I (RE);
  IF LOV = 0;
    WRITE 6 ' *** ERROR, call OV before FR';
    QUIT 0;
  ENDIF;
  LFR := I;
  IF (I < 3) AND (I > 0) AND (LFR2 = 0);
    LFR2 := 1;     { FD2 placeholder — will call FD2 once that ports }
  ENDIF;
ENDPROCEDURE;

{ ----- Phase-space widths (cosy.fox L434-439) ----------------------------- }
PROCEDURE SB PX (RE) PA (RE) R12 (RE) PY (RE) PB (RE) R34 (RE) PT (RE) PD (RE) R56 (RE) PG (RE) PZ (RE);
  IF LOV = 0;
    WRITE 6 ' *** ERROR, call OV before SB';
    QUIT 0;
  ENDIF;
  PHSP[1] := PX; PHSP[2] := PA; PHSP[3] := PY; PHSP[4] := PB;
  PHSP[5] := PT; PHSP[6] := PD; PHSP[7] := PG; PHSP[8] := PZ;
  PHSR[1] := R12; PHSR[2] := R34; PHSR[3] := R56;
  LPS := 1;
ENDPROCEDURE;

{ ----- Parameter widths (cosy.fox L441-443) ------------------------------- }
PROCEDURE SP P1 (RE) P2 (RE) P3 (RE) P4 (RE) P5 (RE) P6 (RE);
  PARS[1] := P1; PARS[2] := P2; PARS[3] := P3;
  PARS[4] := P4; PARS[5] := P5; PARS[6] := P6;
ENDPROCEDURE;

{ ----- Parameter-identifier helper (cosy.fox L428-432) -------------------- }
{ Returns a DA expression `1 + DA(2*ND + I)` when the I-th parameter is in
  scope, else 1 — used by element procedures to weight parameter-dependent
  terms in their kick.                                                     }
FUNCTION (DA) PARA I (RE);
  PARA := 1 + 0*DA(1);
  IF LWA = 1;
    IF TWOND + I < NV;
      PARA := 1 + DA(TWOND + I);
    ENDIF;
  ELSEIF LWA # 1;
    IF TWOND + I < NV + 1;
      PARA := 1 + DA(TWOND + I);
    ENDIF;
  ENDIF;
ENDFUNCTION;

{ ----- Set reference particle (cosy.fox L2782-2798) -----------------------
  RP(E, M, Z) seeds the global reference-particle quantities from a kinetic
  energy E [MeV], mass M [amu], and charge Z [units]. Computes the standard
  relativistic derived values (η, β, γ) and the rigidity coefficients used
  throughout the element families.

  Differences from cosy.fox:
   * The ND=3 branch that promotes E0 to a DA-of-DD(6) is omitted — that
     mode requires a 6D phase space and adds parameter dependence; will
     port alongside the elements that actually use it.
   * The XX setup loop (cosy.fox L2788-2792) and the spin-matrix block
     (XX[21..29]) are deferred — they require partial-index access on
     DD / XX which the M4 ray_io milestone will introduce.
   * cosy.fox saves NOC, raises the order via `CO NO+1` for the
     calculation, then restores via `CO NOM`. The order shuffle is kept
     so derivative orders propagate correctly through SQRT / CONS.    }
PROCEDURE RP E (RE) M (RE) Z (RE);
  VARIABLE (RE) NOM;
  IF LOV # 1;
    WRITE 6 ' *** ERROR, call OV before RP ';
    QUIT 0;
  ENDIF;
  LRP := 1;
  NOM := NOC;
  CO NO+1;
  { Lift the RE parameters into DA-space — the slots are DA-typed so that
    later procedures can mix them freely with DD-bound expressions. }
  E0 := E + 0*DA(1);
  M0 := M + 0*DA(1);
  Z0 := Z + 0*DA(1);
  ETA  := E0/M0/AMUMEV;
  V0   := CLIGHT*SQRT(ETA*(2 + ETA))/(1 + ETA);
  P0   := AMUMEV*M0*SQRT(ETA*(2 + ETA));
  TFAC := ((1 + CONS(ETA))/(2 + CONS(ETA)))*CONS(V0);
  CHIM := (AMU*CLIGHT/EZERO)*M0/Z0*SQRT(ETA*(2 + ETA));
  CHIE := CHIM*V0;
  HFAC := SQRT(SQR(CHIM/CONS(CHIM)) - DD[2]*DD[2] - DD[4]*DD[4]);
  CO NOM;
ENDPROCEDURE;

{ ----- Particle-specific RP shortcuts (cosy.fox L2807-2814) ---------------
  These call RP with the standard atomic-mass and charge values for each
  particle species and stamp the spin-Lorentz factor G0. cosy.fox uses
  procedure-call syntax (e.g. `RP E 1.00727646688 1`) — ports verbatim. }
PROCEDURE RPP E (RE);     { proton  }
  RP E 1.00727646688 1;
  G0 := 1.792847337;
ENDPROCEDURE;

PROCEDURE RPE E (RE);     { electron }
  RP E 5.485799110D-4 (-1);
  G0 := 0.001159652187;
ENDPROCEDURE;

PROCEDURE RPPI E (RE) Z (RE);   { pion (charge configurable) }
  RP E 0.149834758 Z;
  G0 := 0;
ENDPROCEDURE;

PROCEDURE RPMU E (RE);    { muon }
  RP E 0.1134289168 (-1);
  G0 := 0.0011659160;
ENDPROCEDURE;

PROCEDURE RPS LS (RE) G (RE);    { spin-flag + Lorentz-factor override }
  LSPN := LS;
  IF G # 0;
    G0 := G;
  ENDIF;
ENDPROCEDURE;

END;
