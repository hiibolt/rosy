{ ============================================================================
  libcosy/helpers/linear_algebra.rosy — Linear-algebra helpers

  Ported from cosy.fox L129, L176-194.
  ============================================================================ }

BEGIN;

INCLUDE '../globals.rosy';

{ ----- Order-weighted DA norm (cosy.fox L129) -----------------------------
  WABS(X, W) returns the COSY order-weighted norm of the DA X using
  monomial weights from the W vector. The `+ 0*DD(1)` idiom forces the
  argument to be a DA-typed expression even when X is constant — DANOW
  expects a DA, and bare RE / VE inputs would mismatch its signature.   }
FUNCTION (RE) WABS X (DA) W (RE);
  DANOW X + 0*DD[1] W WABS;
ENDFUNCTION;

{ ----- DA map inversion (cosy.fox L176-194) -------------------------------
  MI(M, N, L, IER, NO, NV, NM1) inverts a DA map M of dimension L into N,
  iteratively refining the inverse order-by-order up to NO. The COSY
  algorithm is:

    1. Decompose M[i] = C[i] + LIN[i]*DDA + AN[i]
       where C[i] is the constant part, LIN[i] the linear coefficients
       (extracted with DACLIW), and AN[i] the nonlinear remainder.
    2. Invert the linear matrix LIN via LINV → AI.
    3. Initialize N[i] = AI · DDA (linear-only inverse).
    4. Iterate Newton-style: at each order k=2..NO,
         N := AI · (DDA - AN(N))
       which converges quadratically since each pass picks up one more
       order of correction.
    5. Final substitution to absorb the constant part: shift the basis
       by DDA - C and POLVAL N at that shifted basis.

  NO/NV/NM1 are passed in (cosy.fox convention) — they shadow the
  homonymous globals locally. ROSY's procedure-arg shadowing (added in
  v0.36.x) supports this.

  Constraints: arrays are sized at the libcosy max bound (20) since
  ROSY needs compile-time dimensions. Effective dimensions are bounded
  by the L parameter. POLVAL routes to rosy_polval_da via the DA-array
  dispatch.                                                              }
PROCEDURE MI M N L (RE) IER NO (RE) NV (RE) NM1 (RE);
  VARIABLE (RE 20) C;
  VARIABLE (RE 20 20) AL;
  VARIABLE (RE 20 20) AI;
  VARIABLE (RE 20) CL;
  VARIABLE (DA 20) AN;
  VARIABLE (DA 20) SM;
  VARIABLE (DA 20) DDA;
  VARIABLE (DA 1) SCR;       { DACLIW expects Vec<DA>, so wrap in 1-element array }
  VARIABLE (RE) I;
  VARIABLE (RE) J;
  VARIABLE (RE) K;

  IF L > NV;
    WRITE 6 ' *** ERROR in MI, dim too large';
    QUIT 0;
  ENDIF;

  LOOP I 1 L;
    DDA[I] := DA(I);
    DANOT 1;
    SCR[1] := M[I];
    DANOT NO;
    C[I] := CONS(SCR[1]);
    AN[I] := M[I] - SCR[1];
    DACLIW SCR L CL;
    LOOP J 1 L;
      AL[I, J] := CL[J];
    ENDLOOP;
    N[I] := 0*DD[1];
  ENDLOOP;

  LINV AL AI L L IER;
  IF IER # 0;
    IER := 1;
  ENDIF;

  IF NO > 1;
    POLVAL 101 AN L N L N L;
  ENDIF;

  LOOP I 1 L;
    N[I] := 0*DD[1];
    LOOP J 1 L;
      N[I] := N[I] + AI[I, J] * DDA[J];
    ENDLOOP;
  ENDLOOP;

  LOOP I 2 NO;
    DANOT I;
    POLVAL 0 AN L N L N L;
    LOOP J 1 L;
      SM[J] := 0*DD[1];
      LOOP K 1 L;
        SM[J] := SM[J] + AI[J, K] * (DDA[K] - N[K]);
      ENDLOOP;
    ENDLOOP;
    LOOP J 1 L;
      N[J] := SM[J];
    ENDLOOP;
  ENDLOOP;

  LOOP I 1 L;
    SM[I] := DDA[I] - C[I];
  ENDLOOP;
  POLVAL 1 N L SM L N L;
ENDPROCEDURE;

END;
