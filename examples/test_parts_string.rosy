{ Test REAL, IMAG, TRIM, LTRIM functions }
BEGIN;
    { REAL of RE - identity }
    VARIABLE (RE) x;
    x := 3.14;
    VARIABLE (RE) r;
    r := REAL(x);
    WRITE 6 ST(r);

    { REAL of CM - extracts real part }
    VARIABLE (CM) c;
    c := CM(3.0&4.0);
    r := REAL(c);
    WRITE 6 ST(r);

    { IMAG of RE - returns 0.0 }
    r := IMAG(x);
    WRITE 6 ST(r);

    { IMAG of CM - extracts imaginary part }
    r := IMAG(c);
    WRITE 6 ST(r);

    { TRIM - removes trailing spaces }
    VARIABLE (ST) s;
    VARIABLE (ST) s2;
    s := "hello   ";
    s2 := TRIM(s);
    WRITE 6 s2;

    { LTRIM - removes leading spaces }
    s := "   world";
    s2 := LTRIM(s);
    WRITE 6 s2;

    { TRIM and LTRIM with no spaces }
    s := "noSpaces";
    s2 := TRIM(s);
    WRITE 6 s2;
    s2 := LTRIM(s);
    WRITE 6 s2;

    { TRIM of already trimmed }
    s := "abc";
    s2 := TRIM(s);
    WRITE 6 s2;

END;
