{ ============================================================================
  examples/tutorials/ring_analysis.rosy

  A tutorial-quality showcase of libcosy's ring-analysis pipeline.

  This script builds a small periodic FODO-with-dipole storage-ring cell,
  then exercises the full analysis stack:

    Stage 1 — Setup
      OV / RPP / UM            phase-space + reference particle + identity map

    Stage 2 — Lattice construction
      DP / DL / MQK            dipole, drifts, focusing/defocusing quads

    Stage 3 — Linear analysis
      GT                       Twiss (α, β, γ), tune fraction, contraction R
      FM                       fixed-point search (closed orbit)
      BM                       block-diagonal decomposition

    Stage 4 — Normal-form analysis
      NF                       full DA→CD normal-form transformation
      TS                       amplitude-dependent tune
      RS                       resonance strengths

    Stage 5 — Lie-factorization
      MLF_SCALAR               extract Lie generator F from MAP
      LFM_SCALAR               rebuild MAP from F (round-trip check)

    Stage 6 — Symplectification
      SY                       project MAP onto symplectic via MGF + GFM
      SE                       symplectic-error norm before vs after

    Stage 7 — Map-composition primitives
      ANM                      compose two saved maps
      CATR / TRCA              canonical ↔ TRANSPORT representation
      MR                       time-reversed map

  Run:
    cargo run --release --bin rosy -- run examples/tutorials/ring_analysis.rosy

  Each stage prints a clear header so the output is readable in linear order.
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.0";

VARIABLE (RE) RESULT;
VARIABLE (DA 8) M_TURN;
VARIABLE (DA 8) M_OTHER;
VARIABLE (DA 8) M_REVERSED;
VARIABLE (DA 8) M_TRANSPORT;
VARIABLE (DA 8) M_CANONICAL;

VARIABLE (DA 8) FM_F;
VARIABLE (DA 8) FM_FIXED;
VARIABLE (RE) FM_IER;

VARIABLE (DA 4) GT_F;
VARIABLE (DA 4) GT_MU;
VARIABLE (DA 4) GT_ALPHA;
VARIABLE (DA 4) GT_BETA;
VARIABLE (DA 4) GT_GAMMA;
VARIABLE (DA 4) GT_R;

VARIABLE (DA 8) NF_BASIS;
VARIABLE (CD 4) TS_TUNE;
VARIABLE (CD)   RS_STRENGTHS;

VARIABLE (DA 8) MLF_C;
VARIABLE (DA 8) MLF_M;
VARIABLE (DA)   MLF_F;
VARIABLE (DA 8) MLF_BACK;

VARIABLE (RE) SE_BEFORE;
VARIABLE (RE) SE_AFTER;

WRITE 6 ' ============================================================';
WRITE 6 ' libcosy ring-analysis tutorial';
WRITE 6 ' ============================================================';

{ ----- Stage 1: setup ----- }
WRITE 6 '';
WRITE 6 ' [Stage 1] Phase-space setup';
WRITE 6 '   OV 2 2 0    Order 2, 2D phase space (x, p_x, y, p_y), 0 parameters';
WRITE 6 '   RPP 100     Proton at 100 MeV kinetic';
WRITE 6 '   UM          Identity map seed';
OV 2 2 0;
RPP 100;
UM;
WRITE 6 '   ND     =' ND;
WRITE 6 '   TWOND  =' TWOND;
WRITE 6 '   NV     =' NV;
WRITE 6 '   CONS(P0) =' CONS(P0) ' MeV/c';
WRITE 6 '   CONS(E0) =' CONS(E0) ' MeV';
WRITE 6 '   CONS(CHIM) =' CONS(CHIM) ' (magnetic rigidity factor)';

{ ----- Stage 2: lattice construction ----- }
WRITE 6 '';
WRITE 6 ' [Stage 2] Lattice: DP - DL - MQK(+) - DL - MQK(-) - DL - DP';
WRITE 6 '            (dipole + 2 drifts + focusing quad + drift + defoc';
WRITE 6 '             quad + drift + dipole, periodic cell)';
DP 2.0 5.0 0.05;             { dipole, R=2m, 5 deg, aperture 5cm }
DL 0.5;                      { drift }
MQK 0.2 0.5 0.05;            { focusing quad, K=+0.5 m^-2, L=0.2 m }
DL 0.5;                      { drift }
MQK 0.2 (-0.5) 0.05;         { defocusing quad, K=-0.5 m^-2 }
DL 0.5;                      { drift }
DP 2.0 5.0 0.05;             { dipole }
SNM MAP M_TURN;              { save the one-turn map }
WRITE 6 '   one-turn MAP[1] (x-plane):';
WRITE 6 M_TURN[1];

{ ----- Stage 3: linear analysis ----- }
WRITE 6 '';
WRITE 6 ' [Stage 3] Linear analysis';
WRITE 6 '   GT extracts Twiss (alpha, beta, gamma) and tune fraction';
GT M_TURN FM_F GT_MU GT_ALPHA GT_BETA GT_GAMMA GT_R;
WRITE 6 '   horizontal tune fraction CONS(GT_MU[1])    =' CONS(GT_MU[1]);
WRITE 6 '   horizontal beta          CONS(GT_BETA[1])  =' CONS(GT_BETA[1]);
WRITE 6 '   horizontal alpha         CONS(GT_ALPHA[1]) =' CONS(GT_ALPHA[1]);
WRITE 6 '   horizontal contraction   CONS(GT_R[1])     =' CONS(GT_R[1]);

WRITE 6 '   FM finds the closed orbit (fixed point of one-turn map)';
FM M_TURN FM_FIXED FM_F FM_IER;
WRITE 6 '   FM_IER     =' FM_IER;
WRITE 6 '   FM_FIXED[1] (x-component of fixed-point offset, expect ~0):';
WRITE 6 FM_FIXED[1];

{ ----- Stage 4: normal-form analysis ----- }
WRITE 6 '';
WRITE 6 ' [Stage 4] Normal-form analysis';
WRITE 6 '   NF: full DA-->CD normal-form transformation';
NF 1E-10 NF_BASIS;
WRITE 6 '   NF_BASIS[1] (NF change-of-basis, x):';
WRITE 6 NF_BASIS[1];

WRITE 6 '   TS: amplitude- and parameter-dependent tune';
TS TS_TUNE;
WRITE 6 '   TS_TUNE[1] real part =' REAL(TS_TUNE[1]);

WRITE 6 '   RS: resonance strengths';
RS RS_STRENGTHS;
WRITE 6 '   RS_STRENGTHS [CD scalar]:';
WRITE 6 RS_STRENGTHS;

{ ----- Stage 5: Lie factorization ----- }
WRITE 6 '';
WRITE 6 ' [Stage 5] Lie factorization (round-trip check)';
WRITE 6 '   MLF_SCALAR: extract scalar Lie generator from MAP';
MLF_SCALAR M_TURN MLF_C MLF_M MLF_F 1;
WRITE 6 '   MLF_F (extracted Lie generator):';
WRITE 6 MLF_F;

WRITE 6 '   LFM_SCALAR: rebuild map from generator (round-trip)';
LFM_SCALAR MLF_BACK MLF_C MLF_M MLF_F 1;
WRITE 6 '   round-trip diff (M_TURN - MLF_BACK, expect ~0 in x-plane):';
DMAP M_TURN MLF_BACK 6;

{ ----- Stage 6: symplectification ----- }
WRITE 6 '';
WRITE 6 ' [Stage 6] Symplectification';
WRITE 6 '   SE: symplectic-error norm before SY';
SE_BEFORE := SE(M_TURN);
WRITE 6 '   SE before =' SE_BEFORE;

SNM M_TURN M_OTHER;     { copy for SY (which mutates in place) }
WRITE 6 '   SY: project onto symplectic via MGF + GFM round-trip';
SY M_OTHER;
SE_AFTER := SE(M_OTHER);
WRITE 6 '   SE after  =' SE_AFTER;
WRITE 6 '   (smaller is better — both should be already small for our';
WRITE 6 '    well-truncated FODO map)';

{ ----- Stage 7: map-composition primitives ----- }
WRITE 6 '';
WRITE 6 ' [Stage 7] Map-composition primitives';
WRITE 6 '   MR: time-reversed map';
MR M_TURN M_REVERSED;
WRITE 6 '   MR sample, MAP[1] of reversed:';
WRITE 6 M_REVERSED[1];

WRITE 6 '   CATR: canonical -> TRANSPORT representation';
CATR M_TURN M_TRANSPORT 1.0;
WRITE 6 '   M_TRANSPORT[1]:';
WRITE 6 M_TRANSPORT[1];

WRITE 6 '   TRCA: TRANSPORT -> canonical roundtrip (expect ~M_TURN)';
TRCA M_TRANSPORT M_CANONICAL 1.0;
WRITE 6 '   round-trip diff (M_TURN - M_CANONICAL):';
DMAP M_TURN M_CANONICAL 6;

WRITE 6 '';
WRITE 6 ' ============================================================';
WRITE 6 ' Tutorial complete — all 7 stages exercised end-to-end.';
WRITE 6 ' ============================================================';

END;
