{ Benchmark: PLOOP with nested LOOP for 2D parameter grid }
{ Tests: MPI parallelism with inner serial loops }
{ Outer: 20 PLOOP iterations, Inner: 20 LOOP iterations = 400 total work units }
{ Each unit does 180K arithmetic ops (total work preserved from 6x6x2M) }
BEGIN ;

VARIABLE T1 1 ;
VARIABLE T2 1 ;
VARIABLE OUTER_RESULTS 1 20 ;
VARIABLE INNER_SUM 1 ;
VARIABLE ACC 1 ;
VARIABLE X 1 ;
VARIABLE I 1 ;
VARIABLE J 1 ;
VARIABLE K 1 ;
VARIABLE DT 1 ;

WRITE 6 'PLOOP Nested Benchmark: 20 PLOOP x 20 LOOP, 180K ops per cell' ;

CPUSEC T1 ;

PLOOP I 1 20 ;
    INNER_SUM := 0.0 ;
    LOOP J 1 20 ;
        ACC := 0.0 ;
        X := I * 0.1 + J * 0.01 ;
        LOOP K 1 180000 ;
            ACC := ACC + SIN(X) * COS(X) + X * X ;
            X := X + 0.0000001 ;
        ENDLOOP ;
        INNER_SUM := INNER_SUM + ACC ;
    ENDLOOP ;

    OUTER_RESULTS(I) := INNER_SUM ;
ENDPLOOP OUTER_RESULTS ;

CPUSEC T2 ;

WRITE 6 'Outer Results(1) = ' OUTER_RESULTS(1) ;
WRITE 6 'Outer Results(10) = ' OUTER_RESULTS(10) ;
WRITE 6 'Outer Results(20) = ' OUTER_RESULTS(20) ;
DT := T2 - T1 ;
WRITE 6 'CPUSEC: ' DT ;

END ;
