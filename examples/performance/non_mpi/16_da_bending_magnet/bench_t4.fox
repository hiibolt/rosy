{ Benchmark: DA sector bending magnet with edge focusing }
{ Tests: SIN/COS/SQRT on DA vectors via Taylor composition }
{ Order 5, 4 variables => C(9,4) = 126 monomials per DA vector }
BEGIN ;

VARIABLE T1 1 ;
VARIABLE T2 1 ;
VARIABLE ORDER 1 ;
VARIABLE NVARS 1 ;
VARIABLE NM 1 ;
VARIABLE I 1 ;
VARIABLE DT 1 ;
VARIABLE THETA 1 ;
VARIABLE X 500 ;
VARIABLE PX 500 ;
VARIABLE Y 500 ;
VARIABLE PY 500 ;
VARIABLE XR 500 ;
VARIABLE PXR 500 ;
VARIABLE YR 500 ;
VARIABLE PYR 500 ;
VARIABLE S 500 ;
VARIABLE R 500 ;

ORDER := 5 ;
NVARS := 4 ;
DAINI ORDER NVARS 0 NM ;

X := DA(1) + 0.001 ;
PX := DA(2) + 0.001 ;
Y := DA(3) + 0.001 ;
PY := DA(4) + 0.001 ;

THETA := 0.1 ;

WRITE 6 'DA Bending Magnet Benchmark T4: order 5, 4 vars, 50000 iterations' ;
WRITE 6 'Monomials per DA vector: ' NM ;

CPUSEC T1 ;

LOOP I 1 50000 ;
    { Sector bend rotation }
    XR := X * COS(THETA * (1.0 + PX)) + SIN(THETA * (1.0 + PX)) ;
    PXR := PX * COS(THETA * (1.0 + PX)) - X * SIN(THETA * (1.0 + PX)) ;

    { Edge focusing }
    YR := Y + PY * 0.5 ;
    PYR := PY - 0.3 * Y ;

    { Path length }
    S := SQRT(XR * XR + YR * YR + 1.0) ;
    R := XR + PXR + YR + PYR + S ;
ENDLOOP ;

CPUSEC T2 ;

DT := T2 - T1 ;
WRITE 6 'Result constant part: ' CONS(R) ;
WRITE 6 'CPUSEC: ' DT ;

END ;
