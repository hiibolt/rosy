{ Benchmark: POLVAL map evaluation — full polval.fox pipeline }
{ T3: 100 particles, order 6, 10000 repetitions }
{ Faithful reproduction of cosy_examples/polval.fox with batch POLVAL }
BEGIN;

VARIABLE (RE) T1;
VARIABLE (RE) T2;
VARIABLE (RE) MASS;
VARIABLE (RE) GAMMA0;
VARIABLE (RE) V0;
VARIABLE (RE) P0;
VARIABLE (RE) K0;
VARIABLE (RE) T0;
VARIABLE (RE) NP;
VARIABLE (RE) NREP;
VARIABLE (RE) NM;
VARIABLE (RE) KE;
VARIABLE (RE) TI;
VARIABLE (RE) J;
VARIABLE (RE) K;
VARIABLE (RE) L;
VARIABLE (RE) JJ;
VARIABLE (RE) TEMP;

NP := 100;
NREP := 10000;
MASS := 1;
GAMMA0 := 2.065789024930937;
V0 := 0.8750256596748323;
P0 := GAMMA0 * V0;
K0 := GAMMA0 - 1;

DAINI 6 6 0 NM;

T0 := 0;

{ Build forward map: cartesian -> COSY coordinates }
VARIABLE (DA 6) MAP1;
MAP1(1) := DA(1);
MAP1(2) := DA(2) / P0;
MAP1(3) := DA(3);
MAP1(4) := DA(4) / P0;
MAP1(5) := -(DA(5) - T0) * V0 * GAMMA0 / (1 + GAMMA0);
MAP1(6) := (DA(6) - K0) / K0;

{ Build inverse map: COSY -> cartesian coordinates }
VARIABLE (DA 6) MAP2;
MAP2(1) := DA(1);
MAP2(2) := DA(2) * P0;
MAP2(3) := DA(3);
MAP2(4) := DA(4) * P0;
MAP2(5) := -((DA(5) * (GAMMA0 + 1)) / (V0 * GAMMA0)) + T0;
MAP2(6) := K0 * (DA(6) + 1);

WRITE 6 'POLVAL Benchmark T3: ' ST(NP) ' particles, order 6, ' ST(NREP) ' reps';

{ Particle arrays }
VARIABLE (VE) X;
VARIABLE (VE) Y;
VARIABLE (VE) Z;
VARIABLE (VE) PX;
VARIABLE (VE) PY;
VARIABLE (VE) PZ;

{ Reconstruction arrays }
VARIABLE (VE) XF;
VARIABLE (VE) YF;
VARIABLE (VE) ZF;
VARIABLE (VE) PXF;
VARIABLE (VE) PYF;
VARIABLE (VE) PZF;

{ Phase-space coordinate arrays (batch POLVAL) }
VARIABLE (VE 6) COORD;
VARIABLE (VE 6) COORD2;

CPUSEC T1;

LOOP R 1 NREP;
    { Generate random particles }
    RERAN J; RERAN K; RERAN L; RERAN JJ;
    X := VE(10^(-2) * J);
    Y := VE(10^(-2) * K);
    Z := VE(0);
    PX := VE(2 * 10^(-3) * L);
    PY := VE(2 * 10^(-3) * JJ);
    PZ := VE(P0);

    LOOP I 2 NP;
        RERAN J; RERAN K; RERAN L; RERAN JJ;
        X := X & (10^(-2) * J);
        Y := Y & (10^(-2) * K);
        Z := Z & 0;
        PX := PX & (2 * 10^(-3) * L);
        PY := PY & (2 * 10^(-3) * JJ);
        PZ := PZ & P0;
    ENDLOOP;

    { Build COORD: compute KE and TI per particle }
    LOOP I 1 NP;
        KE := (PX|I)^2 + (PY|I)^2 + (PZ|I)^2;
        KE := KE / (SQRT(KE + MASS^2) + MASS);
        TI := (Z|I) * (KE + MASS) / (PZ|I);
        IF I = 1;
            COORD(1) := VE(X|I);
            COORD(2) := VE(PX|I);
            COORD(3) := VE(Y|I);
            COORD(4) := VE(PY|I);
            COORD(5) := VE(TI);
            COORD(6) := VE(KE);
        ENDIF;
        IF I > 1;
            COORD(1) := COORD(1) & (X|I);
            COORD(2) := COORD(2) & (PX|I);
            COORD(3) := COORD(3) & (Y|I);
            COORD(4) := COORD(4) & (PY|I);
            COORD(5) := COORD(5) & TI;
            COORD(6) := COORD(6) & KE;
        ENDIF;
    ENDLOOP;

    { Forward transform: cartesian -> COSY coordinates (batch) }
    POLVAL 1 MAP1 6 COORD 6 COORD 6;

    { Inverse transform: COSY -> cartesian coordinates (batch) }
    POLVAL 1 MAP2 6 COORD 6 COORD2 6;

    { Reconstruct cartesian from COORD2 }
    LOOP I 1 NP;
        IF I = 1;
            PXF := VE(COORD2(2)|I);
            PYF := VE(COORD2(4)|I);
            PZF := VE(SQRT((COORD2(6)|I)^2 + 2 * MASS * (COORD2(6)|I) - (COORD2(2)|I)^2 - (COORD2(4)|I)^2));
            XF := VE(COORD2(1)|I);
            YF := VE(COORD2(3)|I);
            ZF := VE(PZF|1 * (COORD2(5)|I) / ((COORD2(6)|I) + MASS));
        ENDIF;
        IF I > 1;
            PXF := PXF & (COORD2(2)|I);
            PYF := PYF & (COORD2(4)|I);
            TEMP := SQRT((COORD2(6)|I)^2 + 2 * MASS * (COORD2(6)|I) - (COORD2(2)|I)^2 - (COORD2(4)|I)^2);
            PZF := PZF & TEMP;
            XF := XF & (COORD2(1)|I);
            YF := YF & (COORD2(3)|I);
            ZF := ZF & (TEMP * (COORD2(5)|I) / ((COORD2(6)|I) + MASS));
        ENDIF;
    ENDLOOP;
ENDLOOP;

CPUSEC T2;

WRITE 6 'CPUSEC: ' T2 - T1;

END;
