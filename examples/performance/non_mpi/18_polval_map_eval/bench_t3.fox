{ Benchmark: POLVAL map evaluation — full polval.fox pipeline }
{ T3: 100 particles, order 6, 10000 repetitions }
BEGIN;
    PROCEDURE RUN;
        VARIABLE I 1; VARIABLE J 1; VARIABLE K 1; VARIABLE L 1; VARIABLE JJ 1;
        VARIABLE KE 1; VARIABLE TI 1; VARIABLE MASS 1; VARIABLE TEMP 1;
        VARIABLE COORD 200 6; VARIABLE COORD2 200 6;
        VARIABLE X 200; VARIABLE Y 200; VARIABLE Z 200;
        VARIABLE PX 200; VARIABLE PY 200; VARIABLE PZ 200;
        VARIABLE XF 200; VARIABLE YF 200; VARIABLE ZF 200;
        VARIABLE PXF 200; VARIABLE PYF 200; VARIABLE PZF 200;
        VARIABLE MAP1 11 6; VARIABLE MAP2 11 6;
        VARIABLE P0 1; VARIABLE GAMMA0 1; VARIABLE V0 1; VARIABLE K0 1; VARIABLE T0 1;
        VARIABLE NM 1; VARIABLE NP 1; VARIABLE DIM 1; VARIABLE ORDER 1;
        VARIABLE T1 1; VARIABLE T2 1; VARIABLE R 1; VARIABLE NREP 1;

        NP:=100; NREP:=10000; MASS:=1;
        GAMMA0:=2.065789024930937; V0:=0.8750256596748323;
        P0:=GAMMA0*V0; K0:=GAMMA0-1; DIM:=3; ORDER:=6;
        DAINI ORDER 2*DIM 0 NM;

        T0:=0;
        MAP1(1):=DA(1);
        MAP1(2):=DA(2)/P0;
        MAP1(3):=DA(3);
        MAP1(4):=DA(4)/P0;
        MAP1(5):=-(DA(5)-T0)*V0*GAMMA0/(1+GAMMA0);
        MAP1(6):=(DA(6)-K0)/K0;

        MAP2(1):=DA(1);
        MAP2(2):=DA(2)*P0;
        MAP2(3):=DA(3);
        MAP2(4):=DA(4)*P0;
        MAP2(5):=-((DA(5)*(GAMMA0+1))/(V0*GAMMA0))+T0;
        MAP2(6):=K0*(DA(6)+1);

        WRITE 6 'POLVAL Benchmark T3: ' NP ' particles, order ' ORDER ', ' NREP ' reps';

        CPUSEC T1;

        LOOP R 1 NREP;
            { Generate random particles }
            RERAN J; RERAN K; RERAN L; RERAN JJ;
            X:=10^(-2)*J; Y:=10^(-2)*K; Z:=0;
            PX:=2*10^(-3)*L; PY:=2*10^(-3)*JJ; PZ:=P0;
            LOOP I 2 NP;
                RERAN J; RERAN K; RERAN L; RERAN JJ;
                X:=X&10^(-2)*J; Y:=Y&10^(-2)*K; Z:=Z&0;
                PX:=PX&2*10^(-3)*L; PY:=PY&2*10^(-3)*JJ; PZ:=PZ&P0;
            ENDLOOP;

            { Build COORD: compute KE and TI per particle }
            LOOP I 1 NP;
                KE:=(PX|I)^2+(PY|I)^2+(PZ|I)^2;
                KE:=KE/(SQRT(KE+MASS^2)+MASS);
                TI:=(Z|I)*(KE+MASS)/(PZ|I);
                IF I=1;
                    COORD(1):=(X|I); COORD(2):=(PX|I); COORD(3):=(Y|I);
                    COORD(4):=(PY|I); COORD(5):=(TI); COORD(6):=(KE);
                ELSEIF I>1;
                    COORD(1):=COORD(1)&(X|I); COORD(2):=COORD(2)&(PX|I);
                    COORD(3):=COORD(3)&(Y|I); COORD(4):=COORD(4)&(PY|I);
                    COORD(5):=COORD(5)&TI; COORD(6):=COORD(6)&KE;
                ENDIF;
            ENDLOOP;

            { Forward transform: cartesian -> COSY coordinates }
            POLVAL 1 MAP1 2*DIM COORD 2*DIM COORD 2*DIM;

            { Inverse transform: COSY -> cartesian coordinates }
            POLVAL 1 MAP2 2*DIM COORD 2*DIM COORD2 2*DIM;

            { Reconstruct cartesian from COORD2 }
            LOOP I 1 NP;
                IF I=1;
                    PXF:=(COORD2(2)|I);
                    PYF:=(COORD2(4)|I);
                    PZF:=(SQRT((COORD2(6)|I)^2+2*MASS*(COORD2(6)|I)-(COORD2(2)|I)^2-(COORD2(4)|I)^2));
                    XF:=(COORD2(1)|I);
                    YF:=(COORD2(3)|I);
                    ZF:=(PZF*(COORD2(5)|I)/((COORD2(6)|I)+MASS));
                ELSEIF I>1;
                    PXF:=PXF&(COORD2(2)|I);
                    PYF:=PYF&(COORD2(4)|I);
                    TEMP:=(SQRT((COORD2(6)|I)^2+2*MASS*(COORD2(6)|I)-(COORD2(2)|I)^2-(COORD2(4)|I)^2));
                    PZF:=PZF&TEMP;
                    XF:=XF&(COORD2(1)|I);
                    YF:=YF&(COORD2(3)|I);
                    ZF:=ZF&(TEMP*(COORD2(5)|I)/((COORD2(6)|I)+MASS));
                ENDIF;
            ENDLOOP;
        ENDLOOP;

        CPUSEC T2;
        WRITE 6 'CPUSEC: ' (T2-T1);

    ENDPROCEDURE;
    RUN;
END;
