BEGIN ;

{ Test CPUSEC: assign elapsed CPU time (seconds) to a variable }
VARIABLE (RE) t1 ;
CPUSEC t1 ;

{ t1 should be a non-negative real number }
IF t1 >= 0 ;
  WRITE 6 'CPUSEC ok: t1 is non-negative' ;
ENDIF ;

{ A second call should return a value >= the first }
VARIABLE (RE) t2 ;
CPUSEC t2 ;
IF t2 >= t1 ;
  WRITE 6 'CPUSEC ok: t2 >= t1' ;
ENDIF ;

END ;
