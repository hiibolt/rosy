BEGIN;

VARIABLE (ST) s;
VARIABLE (ST) sub;

s := 'Hello, World!';

{ Extract 'Hello' (positions 1 to 5) }
SUBSTR s 1 5 sub;
WRITE 6 sub;

{ Extract 'World' (positions 8 to 12) }
SUBSTR s 8 12 sub;
WRITE 6 sub;

{ Extract single character 'W' (position 8 to 8) }
SUBSTR s 8 8 sub;
WRITE 6 sub;

END;
