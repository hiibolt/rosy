{ ============================================================================
  test_libcosy_smoke.rosy — Smoke test for libcosy/

  Confirms that:
   * `INCLUDE 'libcosy';` resolves through the directory fallback to
     libcosy/mod.rosy (added in v0.36.0).
   * libcosy/globals.rosy parses and its declarations (PI, NRAY, ...) are
     visible at the top level after splicing.
   * Empty libcosy/{helpers,physics}/mod.rosy stubs INCLUDE cleanly.

  Run with:
    cargo run --bin rosy -- run examples/tests/test_libcosy_smoke.rosy

  Note: globals are uninitialized in M1, so reads return type-default values
  (PI -> 0.0). This test only verifies that the INCLUDE chain succeeds and
  globals are addressable.
  ============================================================================ }

BEGIN;

INCLUDE '../../libcosy';     { resolves to libcosy/mod.rosy }

VARIABLE (RE) RESULT;

WRITE 6 'libcosy loaded successfully.';
WRITE 6 'PI (uninitialized in M1) = ' PI;
WRITE 6 'NRAY (uninitialized in M1) = ' NRAY;

{ M2: exercise helpers/math.rosy }
PI := 3.141592653589793;     { Initialize PI so ATAN2 returns a meaningful value }
RESULT := MAX(3, 7);     WRITE 6 'MAX(3, 7) = ' RESULT;
RESULT := MIN(3, 7);     WRITE 6 'MIN(3, 7) = ' RESULT;
RESULT := MOD(17, 5);    WRITE 6 'MOD(17, 5) = ' RESULT;
RESULT := SIG(-4);       WRITE 6 'SIG(-4) = ' RESULT;
RESULT := FACT(5);       WRITE 6 'FACT(5) = ' RESULT;
RESULT := NMON(3, 2);    WRITE 6 'NMON(3, 2) [monomials, order 3, vars 2] = ' RESULT;
RESULT := ATAN2(1, 1);   WRITE 6 'ATAN2(1, 1) = ' RESULT '   [expect ~0.785]';
RESULT := ATAN2(1, -1);  WRITE 6 'ATAN2(1, -1) = ' RESULT '   [expect ~2.356]';

{ Transitive capture: VATAN2 calls ATAN2 (which captures global PI). }
VARIABLE (VE) VRES;
VRES := VATAN2(1 & 1 & 1, 1 & -1 & 0);
WRITE 6 'VATAN2([1,1,1], [1,-1,0]) = ' VRES '   [expect (~0.785, ~2.356, ~1.571)]';

{ M2: exercise helpers/strings.rosy }
VARIABLE (ST) STR;
STR := SS('Hello, World!', 8, 12);   WRITE 6 'SS(''Hello, World!'', 8, 12) = ''' STR '''   [expect ''World'']';
STR := S(2.5);                        WRITE 6 'S(2.5) = ''' STR '''';
STR := SI(42);                        WRITE 6 'SI(42) = ''' STR '''   [expect ''42'']';
STR := SI(-17);                       WRITE 6 'SI(-17) = ''' STR '''   [expect ''-17'']';
RESULT := ILAST('hello   ', 1, 8);   WRITE 6 'ILAST(''hello   '', 1, 8) = ' RESULT '   [expect 5]';
RESULT := IPOS(',', 'a,b,c');        WRITE 6 'IPOS('','', ''a,b,c'') = ' RESULT '   [expect 2]';

{ TRCAP combines self-ref assignment + mixed-borrow-in-call (ILAST(A, 1, LENGTH(A))). }
VARIABLE (ST) MIXED;
MIXED := 'Hello WORLD';
TRCAP MIXED;
WRITE 6 'TRCAP(''Hello WORLD'') -> ''' MIXED '''   [expect ''HELLO WORLD'']';

{ M3: exercise helpers/da_helpers.rosy
  COSY's TRANSPORT id encoding: leftmost decimal digit = variable 1 exponent.
  id=1 → x₁¹     id=11 → x₁¹·x₂¹     id=2 → x₁² }
DAINI 3 2 0 0;
VARIABLE (DA) F;
F := 3*DA(1) + 5*DA(2) + 7*DA(1)*DA(2);

WRITE 6 'COEF(F, 1)  [x_1     coefficient] = ' COEF(F, 1)  '   [expect 3]';
WRITE 6 'COEF(F, 11) [x_1*x_2 coefficient] = ' COEF(F, 11) '   [expect 7]';

WRITE 6 'DER(1, F) [partial wrt x_1] — expect 3 (constant) + 7*x_2:';
WRITE 6 DER(1, F);
WRITE 6 'INTEG(1, DER(1, F)) — round-trips x_1-dependent terms (5*x_2 is lost):';
WRITE 6 INTEG(1, DER(1, F));

{ M3: exercise helpers/polynomial.rosy::POLY
  Drives type inference for the untyped P param: P is a 3x3 RE table.
  Uses [i,j] indexed-assignment syntax (parens are reserved for fn calls). }
VARIABLE (RE 3 3) PCOEFS;
VARIABLE (RE) ERR_DUMMY;
VARIABLE (RE 25 100) MFD_DUMMY;
PCOEFS[1, 1] := 1;     PCOEFS[1, 2] := 2;     PCOEFS[1, 3] := 0;     { 1 + 2y          }
PCOEFS[2, 1] := 3;     PCOEFS[2, 2] := 0;     PCOEFS[2, 3] := 0;     { + 3x            }
PCOEFS[3, 1] := 0;     PCOEFS[3, 2] := 0;     PCOEFS[3, 3] := 0;
RESULT := POLY(2, 5, PCOEFS, 2);
WRITE 6 'POLY(2, 5, [[1,2,0],[3,0,0],[0,0,0]], order=2) = ' RESULT '   [expect 1+2*5+3*2 = 17]';

{ Drive GAUSS1 / GAUSS inference too. Use MFD-shaped 25x100 dummy. }
RESULT := GAUSS1(0, 100, 1, 2, 1, MFD_DUMMY, ERR_DUMMY);
WRITE 6 'GAUSS1 on zero MFD (sanity) = ' RESULT '   [expect 0]';
RESULT := GAUSS(0, 0, 25, 100, 1, 1, 2, MFD_DUMMY, ERR_DUMMY);
WRITE 6 'GAUSS  on zero MFD (sanity) = ' RESULT '   [expect 0]';

{ M3: exercise physics/fringe_field.rosy
  FD populates ENGEC with default fringe-field coefficients (PEP-fitted). }
FD;
WRITE 6 'After FD, ENGEC[1,1,1,1] = ' ENGEC[1, 1, 1, 1] '   [expect 0.478959 (dipole, entrance, magnetic, c1)]';
WRITE 6 'After FD, ENGEC[2,1,1,2] = ' ENGEC[2, 1, 1, 2] '   [expect 4.533219 (quadrupole, entrance, magnetic, c2)]';

{ Evaluate ENGE at a DA point in the transition window. With S = DA(1)
  (i.e. the symbolic path coordinate at the magnet edge), F should be a
  Taylor series with constant part ~0.5 (the midpoint of the transition). }
VARIABLE (DA) F_ENGE;
F_ENGE := ENGE(1, 1, 1, 0 + DA(1));
WRITE 6 'ENGE(dipole, entrance, magnetic, S=DA(1)):';
WRITE 6 F_ENGE;

{ M3: exercise physics/reference_particle.rosy }
DEF;
WRITE 6 'After DEF, AMU    = ' AMU    '   [expect 1.66053873e-27]';
WRITE 6 'After DEF, CLIGHT = ' CLIGHT '   [expect 2.99792458e8]';
WRITE 6 'After DEF, AMUMEV = ' AMUMEV '   [expect ~931.494]';
WRITE 6 'After DEF, PI     = ' PI     '   [expect ~3.14159265]';
WRITE 6 'After DEF, DEGRAD = ' DEGRAD '   [expect ~0.0174533]';
WRITE 6 'After DEF, EPS    = ' EPS    '   [expect 1e-10]';
WRITE 6 'After DEF, WAF    = ' WAF    '   [expect 0.1]';
WRITE 6 'After DEF, DEPS   = ' DEPS   '   [expect 1e-16]';

{ Control-flow flag setters. }
KC 1;          { kinematic correction off — emits a warning }
WAS 0;         { wedge mode 0 → LWA = 0 }
WRITE 6 'After WAS 0, LWA = ' LWA '   [expect 0]';
CO 2;          { computational order = 2 (must be ≤ DAINI order 3) }
WRITE 6 'After CO 2, NOC  = ' NOC '   [expect 2]';

{ M2: exercise helpers/numerics.rosy }
M0 := 1.00727646688;     { proton mass in u, used by VELC via globals }
AMUMEV := 931.494;
RESULT := VELC(100);     WRITE 6 'VELC(100 MeV proton) = ' RESULT '   [expect ~0.428 (v/c)]';

BBC 13 27 2.7 1.66E-7 0 0;   { Aluminum: Z=13, A=27, density 2.7 g/cm^3, I=166eV; uses scientific notation }
WRITE 6 'BBC: BETHEBLOCHC(1) = ' BETHEBLOCHC(1) '   [expect 13]';
WRITE 6 'BBC: BETHEBLOCHC(3) = ' BETHEBLOCHC(3) '   [expect 2.7]';

END;
