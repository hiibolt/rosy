{ ============================================================================
  test_libcosy_smoke.rosy --Smoke test for libcosy/

  Confirms that:
   * `INCLUDE 'libcosy';` resolves through the directory fallback to
     libcosy/mod.rosy (added in v0.36.0).
   * libcosy/globals.rosy parses and its declarations (PI, NRAY, ...) are
     visible at the top level after splicing.
   * Empty libcosy/{helpers,physics}/mod.rosy stubs INCLUDE cleanly.

  Run with:
    cargo run --bin rosy -- run examples/tests/test_libcosy_smoke.rosy

  Note: globals are uninitialized in M1, so reads return type-default values
  (PI -> 0.0). This test only verifies that the INCLUDE chain succeeds and
  globals are addressable.
  ============================================================================ }

BEGIN;

INCLUDE '../../libcosy';     { resolves to libcosy/mod.rosy }

VARIABLE (RE) RESULT;

WRITE 6 'libcosy loaded successfully.';
WRITE 6 'PI (uninitialized in M1) = ' PI;
WRITE 6 'NRAY (uninitialized in M1) = ' NRAY;

{ M2: exercise helpers/math.rosy }
PI := 3.141592653589793;     { Initialize PI so ATAN2 returns a meaningful value }
RESULT := MAX(3, 7);     WRITE 6 'MAX(3, 7) = ' RESULT;
RESULT := MIN(3, 7);     WRITE 6 'MIN(3, 7) = ' RESULT;
RESULT := MOD(17, 5);    WRITE 6 'MOD(17, 5) = ' RESULT;
RESULT := SIG(-4);       WRITE 6 'SIG(-4) = ' RESULT;
RESULT := FACT(5);       WRITE 6 'FACT(5) = ' RESULT;
RESULT := NMON(3, 2);    WRITE 6 'NMON(3, 2) [monomials, order 3, vars 2] = ' RESULT;
RESULT := ATAN2(1, 1);   WRITE 6 'ATAN2(1, 1) = ' RESULT '   [expect ~0.785]';
RESULT := ATAN2(1, -1);  WRITE 6 'ATAN2(1, -1) = ' RESULT '   [expect ~2.356]';

{ Transitive capture: VATAN2 calls ATAN2 (which captures global PI). }
VARIABLE (VE) VRES;
VRES := VATAN2(1 & 1 & 1, 1 & -1 & 0);
WRITE 6 'VATAN2([1,1,1], [1,-1,0]) = ' VRES '   [expect (~0.785, ~2.356, ~1.571)]';

{ M2: exercise helpers/strings.rosy }
VARIABLE (ST) STR;
STR := SS('Hello, World!', 8, 12);   WRITE 6 'SS(''Hello, World!'', 8, 12) = ''' STR '''   [expect ''World'']';
STR := S(2.5);                        WRITE 6 'S(2.5) = ''' STR '''';
STR := SI(42);                        WRITE 6 'SI(42) = ''' STR '''   [expect ''42'']';
STR := SI(-17);                       WRITE 6 'SI(-17) = ''' STR '''   [expect ''-17'']';
RESULT := ILAST('hello   ', 1, 8);   WRITE 6 'ILAST(''hello   '', 1, 8) = ' RESULT '   [expect 5]';
RESULT := IPOS(',', 'a,b,c');        WRITE 6 'IPOS('','', ''a,b,c'') = ' RESULT '   [expect 2]';

{ TRCAP combines self-ref assignment + mixed-borrow-in-call (ILAST(A, 1, LENGTH(A))). }
VARIABLE (ST) MIXED;
MIXED := 'Hello WORLD';
TRCAP MIXED;
WRITE 6 'TRCAP(''Hello WORLD'') -> ''' MIXED '''   [expect ''HELLO WORLD'']';

{ M3: exercise helpers/da_helpers.rosy
  COSY's TRANSPORT id encoding: leftmost decimal digit = variable 1 exponent.
  id=1 → x₁¹     id=11 → x₁¹·x₂¹     id=2 → x₁² }
DAINI 3 2 0 0;
VARIABLE (DA) F;
F := 3*DA(1) + 5*DA(2) + 7*DA(1)*DA(2);

WRITE 6 'COEF(F, 1)  [x_1     coefficient] = ' COEF(F, 1)  '   [expect 3]';
WRITE 6 'COEF(F, 11) [x_1*x_2 coefficient] = ' COEF(F, 11) '   [expect 7]';

WRITE 6 'DER(1, F) [partial wrt x_1] --expect 3 (constant) + 7*x_2:';
WRITE 6 DER(1, F);
WRITE 6 'INTEG(1, DER(1, F)) --round-trips x_1-dependent terms (5*x_2 is lost):';
WRITE 6 INTEG(1, DER(1, F));

{ M3: exercise helpers/polynomial.rosy::POLY
  Drives type inference for the untyped P param: P is a 3x3 RE table.
  Uses [i,j] indexed-assignment syntax (parens are reserved for fn calls). }
VARIABLE (RE 3 3) PCOEFS;
VARIABLE (RE) ERR_DUMMY;
VARIABLE (RE 25 100) MFD_DUMMY;
PCOEFS[1, 1] := 1;     PCOEFS[1, 2] := 2;     PCOEFS[1, 3] := 0;     { 1 + 2y          }
PCOEFS[2, 1] := 3;     PCOEFS[2, 2] := 0;     PCOEFS[2, 3] := 0;     { + 3x            }
PCOEFS[3, 1] := 0;     PCOEFS[3, 2] := 0;     PCOEFS[3, 3] := 0;
RESULT := POLY(2, 5, PCOEFS, 2);
WRITE 6 'POLY(2, 5, [[1,2,0],[3,0,0],[0,0,0]], order=2) = ' RESULT '   [expect 1+2*5+3*2 = 17]';

{ Drive GAUSS1 / GAUSS inference too. Use MFD-shaped 25x100 dummy. }
RESULT := GAUSS1(0, 100, 1, 2, 1, MFD_DUMMY, ERR_DUMMY);
WRITE 6 'GAUSS1 on zero MFD (sanity) = ' RESULT '   [expect 0]';
RESULT := GAUSS(0, 0, 25, 100, 1, 1, 2, MFD_DUMMY, ERR_DUMMY);
WRITE 6 'GAUSS  on zero MFD (sanity) = ' RESULT '   [expect 0]';

{ M3: exercise physics/fringe_field.rosy
  FD populates ENGEC with default fringe-field coefficients (PEP-fitted). }
FD;
WRITE 6 'After FD, ENGEC[1,1,1,1] = ' ENGEC[1, 1, 1, 1] '   [expect 0.478959 (dipole, entrance, magnetic, c1)]';
WRITE 6 'After FD, ENGEC[2,1,1,2] = ' ENGEC[2, 1, 1, 2] '   [expect 4.533219 (quadrupole, entrance, magnetic, c2)]';

{ Evaluate ENGE at a DA point in the transition window. With S = DA(1)
  (i.e. the symbolic path coordinate at the magnet edge), F should be a
  Taylor series with constant part ~0.5 (the midpoint of the transition). }
VARIABLE (DA) F_ENGE;
F_ENGE := ENGE(1, 1, 1, 0 + DA(1));
WRITE 6 'ENGE(dipole, entrance, magnetic, S=DA(1)):';
WRITE 6 F_ENGE;

{ M3: exercise physics/reference_particle.rosy }
DEF;
WRITE 6 'After DEF, AMU    = ' AMU    '   [expect 1.66053873e-27]';
WRITE 6 'After DEF, CLIGHT = ' CLIGHT '   [expect 2.99792458e8]';
WRITE 6 'After DEF, AMUMEV = ' AMUMEV '   [expect ~931.494]';
WRITE 6 'After DEF, PI     = ' PI     '   [expect ~3.14159265]';
WRITE 6 'After DEF, DEGRAD = ' DEGRAD '   [expect ~0.0174533]';
WRITE 6 'After DEF, EPS    = ' EPS    '   [expect 1e-10]';
WRITE 6 'After DEF, WAF    = ' WAF    '   [expect 0.1]';
WRITE 6 'After DEF, DEPS   = ' DEPS   '   [expect 1e-16]';

{ Control-flow flag setters. }
KC 1;          { kinematic correction off --emits a warning }
WAS 0;         { wedge mode 0 → LWA = 0 }
WRITE 6 'After WAS 0, LWA = ' LWA '   [expect 0]';
CO 2;          { computational order = 2 (must be ≤ DAINI order 3) }
WRITE 6 'After CO 2, NOC  = ' NOC '   [expect 2]';

{ Exercise OV --the gateway setup procedure that every cosy.fox script
  starts with. After this fires, NO/ND/NP/NV/TWOND are set, the DA
  system is re-initialized, and DD holds the basis DA variables.        }
OV 2 1 0;          { order 2, ND=1 (1D phase space), NP=0 parameters }
WRITE 6 'After OV 2 1 0:';
WRITE 6 '  NO    = ' NO    '   [expect 2]';
WRITE 6 '  ND    = ' ND    '   [expect 1]';
WRITE 6 '  TWOND = ' TWOND '   [expect 2]';
WRITE 6 '  NP    = ' NP    '   [expect 0]';
WRITE 6 '  NV    = ' NV    '   [expect 2]';
WRITE 6 '  LOV   = ' LOV   '   [expect 1 --the OV-was-called flag]';
WRITE 6 '  PI    = ' PI    '   [expect ~3.14159 --DEF was called by OV]';

{ M4 minimal: exercise the simple map savers + WABS.
  These calls drive ROSY type inference for the untyped DA-array params. }
VARIABLE (DA 8)   M_SAVE;
VARIABLE (DA 8)   M_OTHER;
VARIABLE (DA 3 3) SPIN_SAVE;
VARIABLE (DA 3 3) SPIN_OTHER;
VARIABLE (RE)     WABS_RESULT;
VARIABLE (VE)     WEIGHTS;

{ Seed MAP[1] / MAP[2] with non-trivial DAs so SM has something to copy. }
MAP[1] := DA(1) + 2*DA(2);
MAP[2] := 3*DA(1) - DA(2);

SM M_SAVE;
WRITE 6 'SM-saved MAP[1]:';
WRITE 6 M_SAVE[1];
WRITE 6 'SM-saved MAP[2]:';
WRITE 6 M_SAVE[2];

SNM M_SAVE M_OTHER;
WRITE 6 'SNM-copied M_SAVE -> M_OTHER, M_OTHER[1]:';
WRITE 6 M_OTHER[1];

{ Spin map savers: SPNR is zero by default; copy round-trip exercises the loops. }
SSM SPIN_SAVE;
SSNM SPIN_SAVE SPIN_OTHER;
WRITE 6 'SSM/SSNM round-trip OK (no print --output is the all-zero default).';

{ WABS: COSY order-weighted norm. WAF is the global weight scalar. }
WABS_RESULT := WABS(MAP[1], 0.1);
WRITE 6 'WABS(MAP[1], 0.1) = ' WABS_RESULT '   [order-weighted norm]';

{ ME: matrix-element extraction from MAP. }
WRITE 6 'ME(1, 1)  [x_1 coefficient of MAP[1]=x_1+2*x_2]      = ' ME(1, 1)  '   [expect 1]';
WRITE 6 'ME(2, 1)  [x_1 coefficient of MAP[2]=3*x_1-x_2]      = ' ME(2, 1)  '   [expect 3]';
WRITE 6 'ME(2, 11) [x_1*x_2 coefficient of MAP[2]=3*x_1-x_2]  = ' ME(2, 11) '   [expect 0]';

{ PB: Poisson bracket {x_1, x_2} = 1 (canonical pair after OV 2 1 0). }
VARIABLE (DA) PB_RESULT;
PB_RESULT := PB(DA(1), DA(2));
WRITE 6 'PB(x_1, x_2) --expect constant 1:';
WRITE 6 PB_RESULT;
PB_RESULT := PB(DA(1)*DA(1), DA(2));
WRITE 6 'PB(x_1^2, x_2) --expect 2*x_1:';
WRITE 6 PB_RESULT;

{ PM: pretty-print the first 5 components of MAP via DAPRV. }
WRITE 6 'PM 6: print MAP[1..5] to stdout (unit 6) --';
PM 6;

{ PNM: print an arbitrary saved map (M_SAVE was populated by SM earlier). }
WRITE 6 'PNM M_SAVE 6: print the snapshot map --';
PNM M_SAVE 6;

{ DMAP: SM saved MAP into M_SAVE, so DMAP(MAP, M_SAVE, …) should be all zero. }
WRITE 6 'DMAP MAP M_SAVE 6: difference of MAP and its snapshot --expect all zero --';
DMAP MAP M_SAVE 6;

{ DSMAP: SSM saved SPNR into SPIN_SAVE; DSMAP(SPNR, SPIN_SAVE, ..) is all zero. }
WRITE 6 'DSMAP SPNR SPIN_SAVE 6: spin-map difference --expect all zero --';
DSMAP SPNR SPIN_SAVE 6;

{ M2: exercise helpers/numerics.rosy
  M0 / AMUMEV are now populated by the RP family (RPP for proton). }
RPP 100;
RESULT := VELC(100);     WRITE 6 'VELC(100 MeV proton) = ' RESULT '   [expect ~0.428 (v/c)]';
WRITE 6 'After RPP 100, CONS(M0) = ' CONS(M0)    '   [expect 1.00728 amu]';
WRITE 6 'After RPP 100, CONS(P0) = ' CONS(P0)    '   [expect ~444.5 MeV/c]';
WRITE 6 'After RPP 100, CONS(V0) = ' CONS(V0)    '   [expect ~1.28e8 m/s = 0.428*CLIGHT]';
WRITE 6 'After RPP 100, G0       = ' G0          '   [expect 1.792847337 (proton anomalous moment)]';

{ UM: set MAP to the identity. After RPP populated XX, UM copies it into
  MAP and MSC. The first TWOND components are the basis DAs (DA(1), DA(2)
  for ND=1), the rest are 0. }
UM;
WRITE 6 'After UM, LUM   = ' LUM '   [expect 1]';
WRITE 6 'After UM, MAP[1] (should be DA(1) = x_1):';
WRITE 6 MAP[1];
WRITE 6 'After UM, MAP[2] (should be DA(2) = x_2):';
WRITE 6 MAP[2];

{ DL: drift of length L. After UM, MAP is identity. After DL L, the
  position component MAP[1] should pick up L * <something> * MAP[2]
  (the canonical drift transformation: x' = x + (L/p_z) p_x). With
  ND=1 and on-momentum (delta_E = delta_M = 0), the kinematic
  pre-factor reduces to L itself. }
DL 0.5;
WRITE 6 'After DL 0.5, MAP[1] (drift transforms x = x + L*x'' approximately):';
WRITE 6 MAP[1];
WRITE 6 'After DL 0.5, MAP[2] (momentum unchanged):';
WRITE 6 MAP[2];

{ Re-setup with 2D phase space for the quadrupole test.
  ND=2 -> 4 phase-space variables: (x, p_x, y, p_y) = DA(1..4). }
OV 2 2 0;
RPP 100;
UM;
WRITE 6 'After OV 2 2 0 + RPP + UM, identity MAP[1] = x = DA(1):';
WRITE 6 MAP[1];

{ MQ: focusing magnetic quadrupole, length 0.5 m, pole-tip field 1.0 T,
  aperture 5 cm. The cosy.fox analytical fast path applies the canonical
  quad map (cosine in focusing plane, hyperbolic-cosine in defocusing).
  After this, MAP[1] picks up the cos(KL)*x + sin(KL)/K*p_x pattern. }
MQ 0.5 1.0 0.05;
WRITE 6 'After MQ 0.5 1.0 0.05, MAP[1] (focusing-plane x map):';
WRITE 6 MAP[1];
WRITE 6 'After MQ, MAP[3] (defocusing-plane y map):';
WRITE 6 MAP[3];

{ MH: sextupole — second-order kick; reset to identity before applying. }
UM;
MH 0.3 0.5 0.05;
WRITE 6 'After UM + MH 0.3 0.5 0.05, MAP[1] (sextupole x kick):';
WRITE 6 MAP[1];
WRITE 6 'After MH, MAP[2] (p_x kick -- picks up x^2, y^2 terms at order 2):';
WRITE 6 MAP[2];

{ FODO cell: focus-drift-defocus-drift, the building block of every
  storage-ring lattice. MQK takes the integrated strength K directly. }
UM;
MQK 0.2 2.0 0.05;        { focusing quad,   K = +2 m^-2, L = 0.2 m  }
DL 1.0;                  { drift,            L = 1.0 m              }
MQK 0.2 (-2.0) 0.05;     { defocusing quad, K = -2 m^-2, L = 0.2 m  }
DL 1.0;                  { drift                                    }
WRITE 6 'After a FODO cell (FQ-D-DQ-D), MAP[1] (x-plane composed map):';
WRITE 6 MAP[1];
WRITE 6 'After FODO cell, MAP[3] (y-plane composed map):';
WRITE 6 MAP[3];

BBC 13 27 2.7 1.66E-7 0 0;   { Aluminum: Z=13, A=27, density 2.7 g/cm^3, I=166eV; uses scientific notation }
WRITE 6 'BBC: BETHEBLOCHC(1) = ' BETHEBLOCHC(1) '   [expect 13]';
WRITE 6 'BBC: BETHEBLOCHC(3) = ' BETHEBLOCHC(3) '   [expect 2.7]';

END;
