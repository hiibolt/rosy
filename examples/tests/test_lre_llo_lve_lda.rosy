BEGIN;
    VARIABLE (RE) R;
    VARIABLE (VE) V;

    { LRE always returns 1 regardless of input }
    R := LRE(0);
    WRITE 6 R;

    R := LRE(1);
    WRITE 6 R;

    R := LRE(100);
    WRITE 6 R;

    { LLO always returns 1 regardless of input }
    R := LLO(0);
    WRITE 6 R;

    R := LLO(1);
    WRITE 6 R;

    R := LLO(-1);
    WRITE 6 R;

    { LVE passes through the value }
    R := LVE(0);
    WRITE 6 R;

    R := LVE(5);
    WRITE 6 R;

    R := LVE(100);
    WRITE 6 R;

    { LDA: order=1, nv=1 -> C(2,1) = 2 }
    V := 1 & 1;
    R := LDA(V);
    WRITE 6 R;

    { LDA: order=2, nv=1 -> C(3,1) = 3 }
    V := 2 & 1;
    R := LDA(V);
    WRITE 6 R;

    { LDA: order=3, nv=2 -> C(5,2) = 10 }
    V := 3 & 2;
    R := LDA(V);
    WRITE 6 R;

    { LDA: order=4, nv=3 -> C(7,3) = 35 }
    V := 4 & 3;
    R := LDA(V);
    WRITE 6 R;

    { LDA: order=0, nv=0 -> C(0,0) = 1 }
    V := 0 & 0;
    R := LDA(V);
    WRITE 6 R;

END;
