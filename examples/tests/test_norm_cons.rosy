{ Test NORM and CONS functions }
BEGIN;
    { NORM of VE - elementwise abs }
    VARIABLE (VE) v;
    VARIABLE (VE) vnorm;
    v := 1.5&-2.5&3.5;
    vnorm := NORM(v);
    WRITE 6 ST(vnorm);

    { NORM of DA - max abs coefficient: 3 + x1 has max coeff = 3 }
    VARIABLE (DA) da;
    VARIABLE (RE) r;
    da := DA(1) + DA(1) + DA(1) + 1.0;
    r := NORM(da);
    WRITE 6 ST(r);

    { CONS of RE - identity }
    VARIABLE (RE) x;
    x := 2.5;
    r := CONS(x);
    WRITE 6 ST(r);

    { CONS of CM - identity }
    VARIABLE (CM) c;
    VARIABLE (CM) cc;
    c := CM(1.5&2.5);
    cc := CONS(c);
    WRITE 6 ST(cc);

    { CONS of VE - max abs value }
    v := 1.5&-2.5&3.5;
    r := CONS(v);
    WRITE 6 ST(r);

    { CONS of DA - constant part: 5 + x1 should return 5 }
    da := DA(1) + DA(1) + DA(1) + DA(1) + DA(1) + 1.0;
    r := CONS(da);
    WRITE 6 ST(r);

END;
