{ ============================================================================
  test_libcosy_spos.rosy — verify s-position tracking through a beamline

  Documents the SPOS values that should accumulate as elements act on
  the active map. Used as a regression check for the M16.5 refactor
  that centralizes SPOS / LTRA / GTRA into UPDATE.
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.0";

OV 2 2 0;
RP 1 1 1;
UM;

WRITE 6 'Initial SPOS (after UM):';
WRITE 6 SPOS;

DL 0.5;
WRITE 6 'After DL 0.5:';
WRITE 6 SPOS;

DL 0.3;
WRITE 6 'After DL 0.3 (cumulative 0.8):';
WRITE 6 SPOS;

MQ 0.1 0.5 0.05;
WRITE 6 'After MQ L=0.1 (cumulative 0.9):';
WRITE 6 SPOS;

DL 0.2;
WRITE 6 'After DL 0.2 (cumulative 1.1):';
WRITE 6 SPOS;

{ Bend with 30 deg and R=1: arc length = R*PHI = pi/6 ~ 0.5236. }
DI 1 30 0.05 0 0 0 0;
WRITE 6 'After DI 30deg/R=1 (adds pi/6 ~ 0.5236, cum ~ 1.6236):';
WRITE 6 SPOS;

END;
