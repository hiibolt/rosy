{ ============================================================================
  test_libcosy_rays.rosy — UPDATE-with-rays + AM-with-rays smoke

  M16 enables AM and UPDATE to push rays through a local element map via
  per-particle POLVAL. Verifies a single ray correctly transports through
  a known drift map.
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.0";

VARIABLE (DA 8) MSC_COPY;
VARIABLE (RE) I;

{ Standard libcosy bring-up. }
OV 2 2 0;
RP 1 1 1;
UM;

{ One ray at x=0.01, a_x=0.001 (1cm offset, 1mrad slope). }
SR 0.01 0.001 0 0 0 0 0 0 1;

WRITE 6 'RAY[1] (x) before AM, after SR:';
WRITE 6 RAY[1];
WRITE 6 'RAY[2] (a_x) before AM:';
WRITE 6 RAY[2];

{ Build a drift map of length L=0.5 in MSC, then compose via AM. }
UMS;
DLACT MSC 0.5;

LOOP I 1 8;
  MSC_COPY[I] := MSC[I];
ENDLOOP;
AM MSC_COPY;

WRITE 6 '----';
WRITE 6 'After AM with drift L=0.5:';
WRITE 6 'RAY[1] (x_new = x + L * a_x = 0.01 + 0.5*0.001 = 0.0105):';
WRITE 6 RAY[1];
WRITE 6 'RAY[2] (a_x unchanged):';
WRITE 6 RAY[2];

END;
