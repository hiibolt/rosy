{ ============================================================================
  test_libcosy_spin_e2e.rosy — end-to-end spin tracking smoke

  Verifies the M19 spin pipeline:
    * RP / UM seeds SPNR to identity (XX[21..29] block).
    * MQ slow-path delegates to FFELE, which calls UPDATEMAP with the
      LSPN=1 SPNMUL branch active.
    * SPNR ends up non-trivial (3×3 DA matrix encoding the cumulative
      Thomas-BMT rotation through the magnet).
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.1";

VARIABLE (RE) I;
VARIABLE (RE) J;

LSPN := 1;
NSPN := 0;
OV 2 2 0;
RPP 100;
UM;

WRITE 6 'After UM with LSPN=1, SPNR (should be 3x3 identity):';
LOOP I 1 3;
  LOOP J 1 3;
    WRITE 6 SPNR[I, J];
  ENDLOOP;
ENDLOOP;

{ Apply a quad: this routes MQ slow-path → FFELE → UPDATEMAP/SPNMUL. }
MQ 0.1 0.5 0.05;

WRITE 6 'After MQ 0.1 0.5 0.05 (LSPN=1), SPNR[1,1] now reflects';
WRITE 6 'the through-element spin rotation:';
WRITE 6 SPNR[1, 1];

{ Apply a small dipole bend — exercises the BEND LSPN=1 path which
  falls through to the SIELE-multipole branch (NT=0 LSPN=1 triggers
  the same NPOL=1 dipole-as-multipole as cosy.fox L3380). }
DP 1 0.1 0.05;
WRITE 6 'After DP (LSPN=1), SPNR[1,1] after dipole:';
WRITE 6 SPNR[1, 1];

END;
