{ ============================================================================
  test_libcosy_helpers.rosy — WORDS / FIELDS / FOURIERTRANS / FILE2VE smoke

  Verifies the spec-incomplete helpers ported in M14:
    * WORDS, FIELDS  — string tokenization (cosy.fox L157-174)
    * FOURIERTRANS    — RE-only DFT (cosy.fox L196-211)
    * FILE2VE         — column extractor (cosy.fox L4558-4574)
  RFILT exercises the same WORDS path; we trust the compile-check.
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.1";

VARIABLE (ST) LIN;
VARIABLE (VE 64) WORD;
VARIABLE (RE) NW;
VARIABLE (RE) K;

{ Standard libcosy bring-up — also primes PI / globals via UM. }
OV 2 2 0;
RP 1 1 1;
UM;

{ ----- WORDS ------------------------------------------------------------- }
LIN := 'hello big world';
WORDS LIN NW WORD ' ';
WRITE 6 'WORDS NW =';
WRITE 6 NW;
LOOP K 1 NW;
  WRITE 6 'token:';
  WRITE 6 LIN | WORD[K];
ENDLOOP;

{ ----- FIELDS ------------------------------------------------------------ }
VARIABLE (VE 64) FLD;
VARIABLE (RE) NF;
LIN := 'a,b,,c';
FIELDS LIN NF FLD ',';
WRITE 6 '----';
WRITE 6 'FIELDS NF =';
WRITE 6 NF;

{ ----- FOURIERTRANS: single-tone signal ---------------------------------- }
VARIABLE (RE 4096) DSAMP;
VARIABLE (RE 4096) FTA;
VARIABLE (RE 4096) FTP;
VARIABLE (RE) L;
VARIABLE (RE) FTO;
L := 64;
FTO := 4;
LOOP K 1 L;
  DSAMP[K] := SIN(2*PI*(K-1)/L);
ENDLOOP;
FOURIERTRANS DSAMP L FTO FTA FTP;
WRITE 6 '----';
WRITE 6 'FOURIERTRANS FTA[1] (DC, should be ~ 0):';
WRITE 6 FTA[1];
WRITE 6 'FOURIERTRANS FTA[2] (should be ~ 1.0):';
WRITE 6 FTA[2];
WRITE 6 'FOURIERTRANS FTA[3] (should be ~ 0):';
WRITE 6 FTA[3];

{ ----- FILE2VE round-trip ------------------------------------------------ }
VARIABLE (VE 64) VEC;
VARIABLE (RE 64) COLS;
OPENF 91 'tmp_file2ve.dat' 'UNKNOWN';
WRITE 91 '# header — should be skipped';
WRITE 91 '1.5 10.0';
WRITE 91 '2.5 20.0';
WRITE 91 '3.5 30.0';
CLOSEF 91;

COLS[1] := 1;
COLS[2] := 2;
FILE2VE 'tmp_file2ve.dat' 2 COLS VEC;
WRITE 6 '----';
WRITE 6 'FILE2VE col 1:';
WRITE 6 VEC[1];
WRITE 6 'FILE2VE col 2:';
WRITE 6 VEC[2];

END;
