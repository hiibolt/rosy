{ Test RKCO - verify key coefficient values from DOP853 Butcher tableau }
BEGIN;
    VARIABLE (VE) C;
    VARIABLE (VE) B;
    VARIABLE (VE) E;
    VARIABLE (VE) A1;
    VARIABLE (VE) A2;
    RKCO C B E A1 A2;
    { c(1)=0, c(2)=0.0526..., c(13)=1.0 }
    WRITE 6 C(1);
    WRITE 6 C(2);
    WRITE 6 C(13);
    { b(1)=0.054293..., b(6)=0.4450... }
    WRITE 6 B(1);
    WRITE 6 B(6);
    { e(1)=0.01312... }
    WRITE 6 E(1);
    { a1(1) = 5.26001519587677318e-2 (row2 of tableau) }
    WRITE 6 A1(1);
    { a2(1) = 3.70920001185047927e-2 (row8 first entry) }
    WRITE 6 A2(1);
END;
