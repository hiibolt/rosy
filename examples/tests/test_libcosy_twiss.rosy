{ ============================================================================
  test_libcosy_twiss.rosy — verify GT's parabolic-boundary branch

  CB(L) negates MAP[1] and MAP[2] in place, turning the identity map into
  the inversion map. The 2×2 x-block becomes diag(-1, -1): A=D=-1, B=CC=0,
  DET=1, COSMU=-1 — exactly the parabolic-boundary case at COSMU=-1 with
  zero off-diagonals. cosy.fox L1520-1526 handles this with the half-tune
  output MU=1/2; libcosy now matches.
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.0";

VARIABLE (DA 8) F_GT;
VARIABLE (DA 4) MU_GT;
VARIABLE (DA 4) ALPHA_GT;
VARIABLE (DA 4) BETA_GT;
VARIABLE (DA 4) GAMMA_GT;
VARIABLE (DA 4) R_GT;

OV 2 2 0;
RP 1 1 1;
UM;

{ Identity map already has COSMU=1, B=CC=0, DET=1 → MU=0 (parabolic+). }
GT MAP F_GT MU_GT ALPHA_GT BETA_GT GAMMA_GT R_GT;
WRITE 6 'After UM (identity), GT parabolic+ results:';
WRITE 6 'MU[1] (should be 0):';
WRITE 6 MU_GT[1];
WRITE 6 'BETA[1] (should be 1):';
WRITE 6 BETA_GT[1];

CB;
GT MAP F_GT MU_GT ALPHA_GT BETA_GT GAMMA_GT R_GT;
WRITE 6 '----';
WRITE 6 'After CB (inversion in x), GT parabolic- results:';
WRITE 6 'MU[1] (should be 0.5 — half-tune from inversion):';
WRITE 6 MU_GT[1];
WRITE 6 'BETA[1] (should be 1):';
WRITE 6 BETA_GT[1];
WRITE 6 'MU[2] (y unchanged → 0):';
WRITE 6 MU_GT[2];

{ A focusing quad has stable x but hyperbolic y. Reset MAP via UM
  then apply MQ; the y-plane (J=2) hits GT's hyperbolic branch. }
UM;
MQ 0.1 0.5 0.05;
GT MAP F_GT MU_GT ALPHA_GT BETA_GT GAMMA_GT R_GT;
WRITE 6 '----';
WRITE 6 'After MQ (y-plane unstable), GT hyperbolic results:';
WRITE 6 'MU[1] (x stable, fractional tune):';
WRITE 6 MU_GT[1];
WRITE 6 'MU[2] (y unstable, real-cast tune is 0):';
WRITE 6 MU_GT[2];

END;
