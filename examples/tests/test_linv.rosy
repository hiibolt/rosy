BEGIN;

{ Declare a 3x3 matrix and its inverse, plus supporting variables }
VARIABLE (RE 3 3) A;
VARIABLE (RE 3 3) B;
VARIABLE (RE) n;
VARIABLE (RE) adim;
VARIABLE (RE) err;

{ Fill A with a diagonal matrix: diag(1, 2, 4) }
A(1)(1) := 1.0;  A(1)(2) := 0.0;  A(1)(3) := 0.0;
A(2)(1) := 0.0;  A(2)(2) := 2.0;  A(2)(3) := 0.0;
A(3)(1) := 0.0;  A(3)(2) := 0.0;  A(3)(3) := 4.0;

n    := 3.0;
adim := 3.0;

LINV A B n adim err;

WRITE 6 'Error flag:' err;
WRITE 6 'B(1)(1):' B(1)(1);
WRITE 6 'B(2)(2):' B(2)(2);
WRITE 6 'B(3)(3):' B(3)(3);

END;
