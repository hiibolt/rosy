{ ============================================================================
  test_libcosy_cocr.rosy — round-trip test for COCR / CRCO

  Verifies COSY ↔ circular representation transforms invert each other.
  Builds an identity-ish CD map IAP = DD[1..NV] (in CD), pushes through
  COCR, then through CRCO, and prints the diagonal coefficients of the
  result. CRCO ∘ COCR should equal the identity to within numerical
  noise on the linear part.
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.0";

VARIABLE (CD 8) IAP;
VARIABLE (CD 8) MID;
VARIABLE (CD 8) BACK;
VARIABLE (CM)   IM;
VARIABLE (RE)   K;

IMUNIT IM;
OV 2 2 0;
RP 1 1 1;
UM;

{ Build IAP = identity (in CD). DD is the global DA basis. }
LOOP K 1 NV;
  IAP[K] := DD[K] + 0*IM;
ENDLOOP;

{ COSY → circular → COSY round-trip. }
COCR IAP MID;
CRCO MID BACK;

WRITE 6 'After CRCO ∘ COCR, BACK[1] linear part (should match DD[1]):';
WRITE 6 BACK[1];
WRITE 6 'BACK[2] linear part (should match DD[2]):';
WRITE 6 BACK[2];
WRITE 6 'BACK[3] linear part (should match DD[3]):';
WRITE 6 BACK[3];
WRITE 6 'BACK[4] linear part (should match DD[4]):';
WRITE 6 BACK[4];

END;
