{ ============================================================================
  examples/libcosy_basic.rosy

  Minimal libcosy demo: pull libcosy from its GitHub Release, set up a 2D
  transverse phase space for a 100 MeV proton, push it through a short
  drift / focusing-quad / drift cell, and print the resulting transfer map.

  Run:
    cargo run --release --bin rosy -- run examples/libcosy_basic.rosy
  ============================================================================ }

BEGIN;

MODULE GITHUB "rosy-team/libcosy" "v1.0.1";

VARIABLE (DA 8) M;

WRITE 6 '----- libcosy basic demo -----';

{ Stage 1: phase-space + reference particle setup. }
OV 2 2 0;     { Order 2, 2D phase space (x, p_x, y, p_y), 0 parameters. }
RPP 100;      { 100 MeV proton reference. }
UM;           { Seed the active MAP with the identity. }

WRITE 6 ' phase-space dim TWOND  =' TWOND;
WRITE 6 ' DA depth        NV     =' NV;
WRITE 6 ' beam momentum   P0     =' CONS(P0) ' MeV/c';
WRITE 6 ' beam energy     E0     =' CONS(E0) ' MeV';

{ Stage 2: a 1.2 m drift / quad / drift cell. }
DL 0.5;                { 0.5 m field-free drift }
MQK 0.2 0.5 0.05;      { focusing quad: L=0.2 m, K=+0.5 m^-2, aperture 5 cm }
DL 0.5;                { 0.5 m drift }

{ Stage 3: snapshot the active map and print it. }
SNM MAP M;
WRITE 6 '----- one-pass transfer map (6 components) -----';
PM 6;

WRITE 6 '----- done -----';

END;
