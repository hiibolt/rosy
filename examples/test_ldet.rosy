{ Test LDET - matrix determinant computation }
BEGIN;

{ Declare a 3x3 matrix and a result variable }
{ (RE 3 3) declares a 2D array of size 3x3 }
VARIABLE (RE 3 3) M;
VARIABLE (RE) DET;
VARIABLE (RE) I;
VARIABLE (RE) J;

{ Initialize a 3x3 identity matrix: det should be 1 }
LOOP I 1 3;
  LOOP J 1 3;
    IF I = J;
      M(I)(J) := 1;
    ELSE;
      M(I)(J) := 0;
    ENDIF;
  ENDLOOP;
ENDLOOP;

LDET M 3 3 DET;
WRITE 6 'det(I_3) = ' DET;

{ 2x2 matrix [[2,3],[1,4]] -> det = 2*4 - 3*1 = 5 }
VARIABLE (RE 2 2) A;
VARIABLE (RE) DET2;
A(1)(1) := 2;
A(1)(2) := 3;
A(2)(1) := 1;
A(2)(2) := 4;

LDET A 2 2 DET2;
WRITE 6 'det([[2,3],[1,4]]) = ' DET2;

END;
