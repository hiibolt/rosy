{ Test DATRN: DA variable transformation x_i -> a_i * x_i + c_i }
BEGIN;

{ Initialize DA with order 3, 2 variables }
DAINI 3 2 0 0;

{ Declare DA vector arrays (1 element each) }
VARIABLE (DA) input 1;
VARIABLE (DA) output 1;

{ Declare scale and shift vectors }
VARIABLE (VE) scales;
VARIABLE (VE) shifts;

{ Set up input: DA(1) = first variable x1 }
input(1) := DA(1);

{ scales(1) = 2.0, scales(2) = 1.0 (a1 = 2 for x1) }
scales := 2.0 & 1.0;

{ shifts(1) = 1.0, shifts(2) = 0.0 (c1 = 1 for x1) }
shifts := 1.0 & 0.0;

{ Apply DATRN: transform x1 -> 2*x1 + 1 for variable index 1 to 1 }
DATRN input scales shifts 1 1 output;

{ Print result: output(1) should have constant term 1 and linear term 2 in x1 }
DAPRV output 1 2 1 6;

END;
