{ Test LSLINE with noisy data near y=2x: (1,2.1),(2,3.9),(3,6.2),(4,7.8) }
{ Expected: slope close to 2, intercept close to 0 }
BEGIN;
    VARIABLE (VE) X;
    VARIABLE (VE) Y;
    VARIABLE (RE) N;
    VARIABLE (RE) A;
    VARIABLE (RE) B;
    X := 1&2&3&4;
    Y := 2.1&3.9&6.2&7.8;
    N := 4;
    LSLINE X Y N A B;
    WRITE 6 A;
    WRITE 6 B;
END;
