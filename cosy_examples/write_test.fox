BEGIN;

PROCEDURE RUN;
    VARIABLE I 1;
    VARIABLE N 1;
    VARIABLE Y 100;

    N := 10;

    {Simple vector}
    Y:=1;
    LOOP I 2 N;
        Y:=Y&I;
    ENDLOOP;
    WRITE 6 Y;

    {Vector with +/-, large and small numbers}
    Y:=1;
    LOOP I 2 N;
        Y:=Y&((-1)^I)*10^(2*I*(-1)^I);
    ENDLOOP;
    WRITE 6 Y;

    {Individual elements}
    LOOP I 1 N;
        WRITE 6 (Y|I);
    ENDLOOP;

    {Strings}
    WRITE 6 'HELLO WORLD';

    {Mixed}
    WRITE 6 'VALUE: ' 3.14159;

ENDPROCEDURE;

RUN;
END;
