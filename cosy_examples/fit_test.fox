BEGIN ;

PROCEDURE RUN ;
  VARIABLE X 1 ;
  VARIABLE Y 1 ;
  VARIABLE OBJ 1 ;

  { Test 1: Simplex optimizer - find min of (X-3)^2 + (Y-7)^2 }
  X := 0 ;
  Y := 0 ;

  FIT X Y ;
    OBJ := (X - 3)*(X - 3) + (Y - 7)*(Y - 7) ;
  ENDFIT 1E-10 1000 1 OBJ ;

  WRITE 6 'SIMPLEX RESULT: X=' X 'Y=' Y 'OBJ=' OBJ ;

  { Test 2: LMDIF optimizer - same problem }
  X := 0 ;
  Y := 0 ;

  FIT X Y ;
    OBJ := (X - 3)*(X - 3) + (Y - 7)*(Y - 7) ;
  ENDFIT 1E-10 1000 4 OBJ ;

  WRITE 6 'LMDIF RESULT: X=' X 'Y=' Y 'OBJ=' OBJ ;

  { Test 3: max=0 means execute body once, no optimization }
  X := 5 ;
  Y := 10 ;

  FIT X Y ;
    OBJ := (X - 3)*(X - 3) + (Y - 7)*(Y - 7) ;
  ENDFIT 1E-10 0 1 OBJ ;

  WRITE 6 'NO-OPT RESULT: X=' X 'Y=' Y 'OBJ=' OBJ ;

ENDPROCEDURE ;

RUN ;

END ;
